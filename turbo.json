{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "package.json",
    "bun.lock",
    "bunfig.toml",
    "turbo.json",
    "tsconfig.json",
    "tsconfig.base.json",
    "tsconfig.dist-paths.json",
    "tsconfig.build.template.json",
    "plugins/tsconfig.build.shared.json",
    "packages/feed/packages/tsconfig.base.json"
  ],
  "globalEnv": [
    "BUN_PATH",
    "ELIZA_CERT_QUEUE_HOST",
    "ELIZA_GPU_VISION_CACHE",
    "ELIZA_GPU_VISION_PORT",
    "ELIZA_SCENARIO_MATRIX_ENABLED",
    "SEARCHBENCH_CORPUS",
    "SEARCHBENCH_LATENCY_REPEATS"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["@elizaos/core#build", "^build"],
      "env": ["LOG_LEVEL"],
      "outputs": ["dist/**"],
      "inputs": [
        "src/**",
        "index.ts",
        "index.node.ts",
        "index.browser.ts",
        "build.ts",
        "build.mjs",
        "build.config.ts",
        "scripts/**",
        "tsup.config.ts",
        "tsup.config.*.ts",
        "tsdown.config.ts",
        "vite.config.ts",
        "vite.config.*.ts",
        "tsconfig.json",
        "tsconfig.*.json",
        "package.json",
        "assets/**",
        "public/**",
        "$TURBO_ROOT$/plugins/tsup.plugin-packages.shared.ts",
        "$TURBO_ROOT$/packages/scripts/view-bundle-vite.config.ts",
        "$TURBO_ROOT$/packages/scripts/rewrite-dist-relative-imports-node-esm.mjs"
      ]
    },
    "@elizaos/app#build": {
      "dependsOn": ["@elizaos/core#build", "^build"],
      "env": [
        "LOG_LEVEL",
        "ELIZA_BUILD_STAMP",
        "ELIZA_BUILD_VARIANT",
        "ELIZA_RELEASE_AUTHORITY",
        "VITE_ENVIRONMENT"
      ],
      "outputs": ["dist/**"],
      "inputs": [
        "src/**",
        "index.ts",
        "index.node.ts",
        "index.browser.ts",
        "build.ts",
        "build.mjs",
        "build.config.ts",
        "scripts/**",
        "tsup.config.ts",
        "tsup.config.*.ts",
        "tsdown.config.ts",
        "vite.config.ts",
        "vite.config.*.ts",
        "tsconfig.json",
        "tsconfig.*.json",
        "package.json",
        "assets/**",
        "public/**",
        "$TURBO_ROOT$/plugins/tsup.plugin-packages.shared.ts",
        "$TURBO_ROOT$/packages/scripts/view-bundle-vite.config.ts",
        "$TURBO_ROOT$/packages/scripts/rewrite-dist-relative-imports-node-esm.mjs"
      ]
    },
    "@elizaos/cloud-api#build": {
      "dependsOn": ["@elizaos/core#build", "^build"],
      "outputs": []
    },
    "@elizaos/lifeops-bench#build": {
      "dependsOn": ["@elizaos/core#build", "^build"],
      "outputs": []
    },
    "@elizaos/example-browser-extension-safari#build": {
      "dependsOn": ["@elizaos/core#build", "^build"],
      "outputs": []
    },
    "@elizaos/example-clone-ur-crush#build": {
      "dependsOn": ["@elizaos/core#build", "^build"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "@elizaos/ios-native-deps#build": {
      "dependsOn": ["@elizaos/core#build", "^build"],
      "env": [
        "DEVELOPER_DIR",
        "ELIZA_IOS_MIN_VERSION",
        "ELIZA_LLAMA_BUILD_IOS",
        "ELIZA_LLAMA_FORCE_REBUILD",
        "ELIZA_LLAMA_SIM_METAL",
        "ELIZA_SQLITE_VEC_BUILD_IOS",
        "ELIZA_SQLITE_VEC_FORCE_REBUILD",
        "LLAMA_CPP_REPO",
        "SQLITE_VEC_REPO"
      ],
      "inputs": [
        "package.json",
        "VERSIONS",
        "llama.cpp/build-ios.sh",
        "llama.cpp/shim/**",
        "sqlite-vec/build-ios.sh"
      ],
      "outputs": [
        ".turbo/native-deps-build/**",
        "llama.cpp/dist/**",
        "sqlite-vec/dist/**"
      ]
    },
    "@elizaos/prompts#build": {
      "dependsOn": ["@elizaos/core#build", "^build"],
      "outputs": [
        "specs/actions/plugins.generated.json",
        "$TURBO_ROOT$/packages/core/src/generated/action-docs.ts"
      ],
      "inputs": [
        "package.json",
        "scripts/**",
        "src/**",
        "specs/**",
        "$TURBO_ROOT$/plugins/**/*.ts"
      ]
    },
    "@elizaos/app-core#build": {
      "dependsOn": [
        "@elizaos/core#build",
        "@elizaos/agent#build",
        "@elizaos/shared#build",
        "@elizaos/ui#build"
      ],
      "env": ["LOG_LEVEL"],
      "outputs": ["dist/**"]
    },
    "@elizaos/ui#build": {
      "dependsOn": [
        "@elizaos/cloud-sdk#build",
        "@elizaos/core#build",
        "@elizaos/shared#build"
      ],
      "env": ["LOG_LEVEL"],
      "outputs": ["dist/**"]
    },
    "@elizaos/example-app-capacitor-backend#build": {
      "dependsOn": ["@elizaos/core#build", "^build"],
      "outputs": []
    },
    "@elizaos/plugin-aosp-local-inference#build": {
      "dependsOn": ["@elizaos/core#build", "^build"],
      "outputs": []
    },
    "eliza-next-example#build": {
      "dependsOn": ["@elizaos/core#build", "^build"],
      "outputs": []
    },
    "elizaos-plugin-echo#build": {
      "dependsOn": ["@elizaos/core#build", "^build"],
      "outputs": []
    },
    "@elizaos/core#build": {
      "dependsOn": [
        "@elizaos/contracts#build",
        "@elizaos/logger#build",
        "@elizaos/cloud-routing#build"
      ],
      "env": ["LOG_LEVEL"],
      "outputs": ["dist/**", "src/i18n/generated/**"],
      "inputs": [
        "src/**",
        "build.ts",
        "tsconfig.declarations.json",
        "$TURBO_ROOT$/packages/shared/scripts/generate-keywords.mjs",
        "$TURBO_ROOT$/packages/shared/src/i18n/keywords/*.keywords.json"
      ]
    },
    "@elizaos/contracts#build": {
      "dependsOn": [],
      "outputs": ["dist/**"]
    },
    "@elizaos/cloud-routing#build": {
      "dependsOn": [],
      "outputs": ["dist/**"]
    },
    "@elizaos/logger#build": {
      "dependsOn": [],
      "outputs": ["dist/**"]
    },
    "@elizaos/electrobun#build": {
      "dependsOn": ["@elizaos/app#build", "^build"],
      "cache": false,
      "outputs": []
    },
    "@elizaos/plugin-cli#build": {
      "dependsOn": ["@elizaos/core#build", "^build"],
      "outputs": ["dist/**"]
    },
    "@elizaos/plugin-app-control#build": {
      "dependsOn": ["@elizaos/core#build", "^build"],
      "outputs": ["dist/**"]
    },
    "@elizaos/plugin-pdf#build": {
      "dependsOn": ["@elizaos/core#build", "^build"],
      "outputs": ["dist/**"]
    },
    "@elizaos/plugin-wallet#build": {
      "dependsOn": ["@elizaos/core#build", "^build"],
      "outputs": ["dist/**"]
    },
    "@elizaos/plugin-sql#build": {
      "dependsOn": ["@elizaos/core#build", "^build"],
      "outputs": ["src/dist/**"]
    },
    "@elizaos/native-activity-tracker#build": {
      "dependsOn": ["@elizaos/core#build"],
      "outputs": ["dist/**"]
    },
    "@elizaos/scenario-runner#build": {
      "dependsOn": [
        "@elizaos/core#build",
        "@elizaos/agent#build",
        "@elizaos/shared#build",
        "@elizaos/vault#build",
        "@elizaos/app-core#build",
        "@elizaos/plugin-sql#build",
        "@elizaos/plugin-telegram#build",
        "@elizaos/plugin-streaming#build",
        "@elizaos/plugin-signal#build",
        "@elizaos/plugin-browser#build",
        "@elizaos/plugin-elizacloud#build",
        "@elizaos/ui#build"
      ],
      "outputs": ["dist/**"]
    },
    "lint": {
      "outputs": []
    },
    "lint:check": {
      "outputs": []
    },
    "typecheck": {
      "dependsOn": [
        "@elizaos/core#build",
        "@elizaos/shared#build",
        "@elizaos/ui#build",
        "@elizaos/app-core#build",
        "@elizaos/plugin-agent-skills#build",
        "@elizaos/plugin-app-manager#build",
        "@elizaos/plugin-inbox#build",
        "@elizaos/plugin-sql#build",
        "@elizaos/plugin-task-coordinator#build"
      ],
      "outputs": []
    },
    "@elizaos/app-core#typecheck": {
      "dependsOn": [
        "@elizaos/core#build",
        "@elizaos/shared#build",
        "@elizaos/agent#build",
        "^build"
      ],
      "outputs": []
    },
    "@elizaos/app#typecheck": {
      "dependsOn": [
        "@elizaos/plugin-browser#build",
        "@elizaos/plugin-personal-assistant#build",
        "@elizaos/ui#build"
      ],
      "outputs": []
    },
    "@elizaos/cloud-api#typecheck": {
      "outputs": []
    },
    "@elizaos/cloud-shared#typecheck": {
      "dependsOn": ["@elizaos/plugin-cloud-apps#build"],
      "outputs": []
    },
    "@elizaos/plugin-discord#typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "@elizaos/plugin-tailscale#typecheck": {
      "dependsOn": ["@elizaos/plugin-tunnel#build"],
      "outputs": []
    },
    "@elizaos/plugin-calendar#typecheck": {
      "dependsOn": [],
      "outputs": []
    },
    "@elizaos/plugin-personal-assistant#typecheck": {
      "dependsOn": [
        "@elizaos/plugin-blocker#build",
        "@elizaos/plugin-calendar#build",
        "@elizaos/plugin-calendly#build",
        "@elizaos/plugin-finances#build",
        "@elizaos/plugin-goals#build",
        "@elizaos/plugin-health#build",
        "@elizaos/plugin-inbox#build",
        "@elizaos/plugin-reminders#build",
        "@elizaos/plugin-remote-desktop#build",
        "@elizaos/plugin-x#build",
        "@elizaos/capacitor-mobile-signals#build",
        "@elizaos/macosreminders#build",
        "@elizaos/native-activity-tracker#build"
      ],
      "outputs": []
    },
    "@elizaos/plugin-contacts#typecheck": {
      "dependsOn": [
        "@elizaos/capacitor-contacts#build",
        "@elizaos/ui#build",
        "^build"
      ],
      "outputs": []
    },
    "@elizaos/plugin-hyperliquid#typecheck": {
      "dependsOn": [
        "@elizaos/app-core#build",
        "@elizaos/core#build",
        "@elizaos/shared#build",
        "@elizaos/ui#build",
        "^build"
      ],
      "outputs": []
    },
    "@elizaos/plugin-capacitor-bridge#typecheck": {
      "dependsOn": ["@elizaos/core#build", "@elizaos/shared#build", "^build"],
      "outputs": []
    },
    "@elizaos/example-autonomous#typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "@elizaos/example-telegram#typecheck": {
      "dependsOn": [
        "@elizaos/plugin-openai#build",
        "@elizaos/plugin-sql#build",
        "@elizaos/plugin-telegram#build"
      ],
      "outputs": []
    },
    "@elizaos/example-bluesky#typecheck": {
      "dependsOn": [
        "@elizaos/plugin-bluesky#build",
        "@elizaos/plugin-openai#build",
        "@elizaos/plugin-sql#build"
      ],
      "outputs": []
    },
    "@elizaos/example-chat#typecheck": {
      "dependsOn": ["@elizaos/plugin-sql#build"],
      "outputs": []
    },
    "@elizaos/gcp-examples#typecheck": {
      "dependsOn": [
        "@elizaos/core#build",
        "@elizaos/plugin-openai#build",
        "@elizaos/plugin-sql#build"
      ],
      "outputs": []
    },
    "@elizaos/scenario-runner#typecheck": {
      "dependsOn": ["@elizaos/plugin-browser#build", "^build"],
      "outputs": []
    },
    "@elizaos/example-edad#typecheck": {
      "dependsOn": ["@elizaos/cloud-sdk#build", "^build"],
      "outputs": []
    },
    "@elizaos/example-trader-ts#typecheck": {
      "dependsOn": ["@elizaos/plugin-wallet#build"],
      "outputs": []
    },
    "@elizaos/example-a2a-server#typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "@elizaos/example-app-electron#typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "@elizaos/example-browser-extension-chrome#typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "@elizaos/example-convex#typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "@elizaos/example-rest-api-elysia#typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "@elizaos/example-rest-api-express#typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "@elizaos/example-rest-api-hono#typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "@elizaos/example-xai-x#typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "eliza-react-example#typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "@elizaos/plugin-training#typecheck": {
      "dependsOn": ["@elizaos/plugin-inbox#build", "^build"],
      "outputs": []
    },
    "@elizaos/plugin-sub-agent-claude-code#typecheck": {
      "dependsOn": ["@elizaos/plugin-remote-manifest#build", "^build"],
      "outputs": []
    },
    "@elizaos/plugin-local-inference#typecheck": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "@elizaos/gcp-examples#build": {
      "dependsOn": [
        "@elizaos/core#build",
        "@elizaos/plugin-openai#build",
        "@elizaos/plugin-sql#build"
      ],
      "outputs": ["dist/**"]
    },
    "format": {
      "outputs": []
    },
    "format:check": {
      "outputs": []
    },
    "start": {
      "dependsOn": ["@elizaos/core#build"],
      "env": ["LOG_LEVEL"],
      "cache": false,
      "persistent": true
    },
    "dev": {
      "dependsOn": ["@elizaos/core#build"],
      "cache": false,
      "persistent": true
    },
    "migrate": {
      "dependsOn": ["@elizaos/core#build"],
      "cache": false
    },
    "migrate:generate": {
      "dependsOn": ["@elizaos/core#build"],
      "cache": false
    },
    "clean": {
      "cache": false
    }
  }
}
