          "schema": {
            "type": "string"
          }
        }
      ],
      "similes": ["/context", "/ctx"]
    },
    {
      "name": "ELEVATED_COMMAND",
      "description": "Set elevated permission mode",
      "parameters": [
        {
          "name": "level",
          "description": "off, on, ask, full",
          "required": false,
          "schema": {
            "type": "string"
          }
        }
      ],
      "similes": ["/elevated", "/elev"]
