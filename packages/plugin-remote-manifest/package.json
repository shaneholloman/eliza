{
  "name": "@elizaos/plugin-remote-manifest",
  "version": "0.0.1",
  "description": "Manifest schema, permissions, store, and wire envelope types for remote-mode elizaOS plugins.",
  "type": "module",
  "main": "./dist/index.js",
  "license": "MIT",
  "private": true,
  "files": [
    "dist",
    "sandbox"
  ],
  "scripts": {
    "clean": "node ../scripts/rm-path-recursive.mjs dist",
    "build": "node ../scripts/rm-path-recursive.mjs dist tsconfig.build.tsbuildinfo && tsc --noCheck -p tsconfig.build.json",
    "typecheck": "tsgo --noEmit -p tsconfig.json",
    "test": "bun test src/",
    "lint": "bunx @biomejs/biome check --write --unsafe src",
    "lint:check": "bunx @biomejs/biome check src",
    "lint:fix": "bunx @biomejs/biome check --write --unsafe src",
    "format": "bunx @biomejs/biome format --write src",
    "format:check": "bunx @biomejs/biome format src",
    "format:fix": "bunx @biomejs/biome format --write src"
  },
  "dependencies": {
    "@elizaos/security": "workspace:*"
  },
  "devDependencies": {
    "bun-types": "^1.3.12",
    "typescript": "^6.0.3"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "default": "./dist/types.js"
    },
    "./permissions": {
      "types": "./dist/permissions.d.ts",
      "import": "./dist/permissions.js",
      "default": "./dist/permissions.js"
    },
    "./manifest": {
      "types": "./dist/manifest.d.ts",
      "import": "./dist/manifest.js",
      "default": "./dist/manifest.js"
    },
    "./store": {
      "types": "./dist/store.d.ts",
      "import": "./dist/store.js",
      "default": "./dist/store.js"
    },
    "./validation": {
      "types": "./dist/validation.d.ts",
      "import": "./dist/validation.js",
      "default": "./dist/validation.js"
    },
    "./rpc-mac": {
      "types": "./dist/rpc-mac.d.ts",
      "import": "./dist/rpc-mac.js",
      "default": "./dist/rpc-mac.js"
    },
    "./signature": {
      "types": "./dist/signature.d.ts",
      "import": "./dist/signature.js",
      "default": "./dist/signature.js"
    },
    "./host-shim": {
      "types": "./dist/host-shim/index.d.ts",
      "eliza-source": {
        "types": "./src/host-shim/index.ts",
        "import": "./src/host-shim/index.ts",
        "default": "./src/host-shim/index.ts"
      },
      "import": "./dist/host-shim/index.js",
      "default": "./dist/host-shim/index.js"
    },
    "./host-shim/web": {
      "types": "./dist/host-shim/web.d.ts",
      "import": "./dist/host-shim/web.js",
      "default": "./dist/host-shim/web.js"
    },
    "./host-shim/android": {
      "types": "./dist/host-shim/android/index.d.ts",
      "import": "./dist/host-shim/android/index.js",
      "default": "./dist/host-shim/android/index.js"
    },
    "./host-shim/ios": {
      "types": "./dist/host-shim/ios/index.d.ts",
      "import": "./dist/host-shim/ios/index.js",
      "default": "./dist/host-shim/ios/index.js"
    },
    "./host-shim/electrobun": {
      "types": "./dist/host-shim/electrobun/index.d.ts",
      "import": "./dist/host-shim/electrobun/index.js",
      "default": "./dist/host-shim/electrobun/index.js"
    },
    "./worker-runtime": {
      "types": "./dist/worker-runtime/index.d.ts",
      "import": "./dist/worker-runtime/index.js",
      "default": "./dist/worker-runtime/index.js"
    },
    "./worker-runtime/error": {
      "types": "./dist/worker-runtime/error.d.ts",
      "import": "./dist/worker-runtime/error.js",
      "default": "./dist/worker-runtime/error.js"
    },
    "./worker-runtime/bootstrap": {
      "types": "./dist/worker-runtime/bootstrap.d.ts",
      "import": "./dist/worker-runtime/bootstrap.js",
      "default": "./dist/worker-runtime/bootstrap.js"
    },
    "./worker-runtime/runtime-proxy": {
      "types": "./dist/worker-runtime/runtime-proxy.d.ts",
      "import": "./dist/worker-runtime/runtime-proxy.js",
      "default": "./dist/worker-runtime/runtime-proxy.js"
    },
    "./worker-runtime/descriptor": {
      "types": "./dist/worker-runtime/descriptor.d.ts",
      "import": "./dist/worker-runtime/descriptor.js",
      "default": "./dist/worker-runtime/descriptor.js"
    },
    "./worker-runtime/dispatch": {
      "types": "./dist/worker-runtime/dispatch.d.ts",
      "import": "./dist/worker-runtime/dispatch.js",
      "default": "./dist/worker-runtime/dispatch.js"
    },
    "./worker-runtime/envelope": {
      "types": "./dist/worker-runtime/envelope.d.ts",
      "import": "./dist/worker-runtime/envelope.js",
      "default": "./dist/worker-runtime/envelope.js"
    },
    "./sub-agent-claude-code": {
      "types": "./dist/sub-agent-claude-code/plugin.d.ts",
      "import": "./dist/sub-agent-claude-code/plugin.js",
      "default": "./dist/sub-agent-claude-code/plugin.js"
    },
    "./sub-agent-claude-code/worker": {
      "types": "./dist/sub-agent-claude-code/worker.d.ts",
      "import": "./dist/sub-agent-claude-code/worker.js",
      "default": "./dist/sub-agent-claude-code/worker.js"
    },
    "./sub-agent-claude-code/sub-agent-service": {
      "types": "./dist/sub-agent-claude-code/sub-agent-service.d.ts",
      "import": "./dist/sub-agent-claude-code/sub-agent-service.js",
      "default": "./dist/sub-agent-claude-code/sub-agent-service.js"
    },
    "./sub-agent-claude-code/sandbox": {
      "types": "./dist/sub-agent-claude-code/sandbox.d.ts",
      "import": "./dist/sub-agent-claude-code/sandbox.js",
      "default": "./dist/sub-agent-claude-code/sandbox.js"
    },
    "./sub-agent-claude-code/session-recorder": {
      "types": "./dist/sub-agent-claude-code/session-recorder.d.ts",
      "import": "./dist/sub-agent-claude-code/session-recorder.js",
      "default": "./dist/sub-agent-claude-code/session-recorder.js"
    }
  }
}
