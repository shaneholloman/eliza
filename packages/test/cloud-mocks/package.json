{
  "name": "@elizaos/cloud-test-mocks",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./hetzner": "./src/hetzner/index.ts",
    "./control-plane": "./src/control-plane/index.ts"
  },
  "bin": {
    "hetzner-mock": "./bin/hetzner-mock.ts",
    "control-plane-mock": "./bin/control-plane-mock.ts"
  },
  "scripts": {
    "start:hetzner": "bun run ./bin/hetzner-mock.ts",
    "start:control-plane": "bun run ./bin/control-plane-mock.ts",
    "test": "bun test",
    "format": "bunx @biomejs/biome format --write package.json src test bin",
    "format:check": "bunx @biomejs/biome format package.json src test bin"
  },
  "dependencies": {
    "@elizaos/cloud-shared": "workspace:*",
    "hono": "4.12.25"
  },
  "devDependencies": {
    "bun-types": "*"
  }
}
