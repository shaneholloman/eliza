{
  "name": "@elizaos/cloud-shared",
  "version": "0.1.0",
  "description": "Shared backend code for Eliza Cloud: billing, db schemas/repositories, services lib, types, and route resolution.",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./billing": "./src/billing/index.ts",
    "./db": "./src/db/index.ts",
    "./db/*.ts": "./src/db/*.ts",
    "./db/*": "./src/db/*.ts",
    "./lib": "./src/lib/index.ts",
    "./lib/*.ts": "./src/lib/*.ts",
    "./lib/*": "./src/lib/*.ts",
    "./types": "./src/types/index.ts",
    "./types/*.ts": "./src/types/*.ts",
    "./types/*": "./src/types/*.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build:linked-workspaces": "bun run --cwd ../../.. build:core",
    "lint": "bunx @biomejs/biome check .",
    "lint:fix": "bunx @biomejs/biome check --write .",
    "typecheck": "tsgo --noEmit",
    "check:tenant-scope": "bun scripts/check-tenant-scope.ts",
    "check:tenant-scope:self-test": "bun test scripts/check-tenant-scope.test.ts",
    "verify:tenant-isolation": "bun scripts/verify-tenant-db-isolation.ts",
    "test": "bun test --isolate",
    "test:vitest": "vitest run",
    "preflight:messaging-gateways": "node scripts/messaging-gateway-preflight.mjs",
    "preflight:messaging-gateways:strict": "node scripts/messaging-gateway-preflight.mjs --strict",
    "db:check-migrations": "drizzle-kit check",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run ../../../packages/scripts/cloud/admin/migrate-with-diagnostics.ts",
    "db:migrate:drizzle": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "pglite:server": "bun run ../../../packages/scripts/cloud/admin/dev/pglite-server.ts",
    "generate:email-templates": "node scripts/generate-email-templates.mjs"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.72",
    "@ai-sdk/gateway": "^3.0.37",
    "@ai-sdk/openai": "^3.0.54",
    "@aws-sdk/client-kms": "^3.1047.0",
    "@aws-sdk/client-s3": "^3.1039.0",
    "@brighter/storage-adapter-s3": "^1.6.3",
    "@electric-sql/pglite": "^0.4.5",
    "@electric-sql/pglite-socket": "0.1.6",
    "@elevenlabs/elevenlabs-js": "^2.45.0",
    "@elizaos/app-core": "workspace:*",
    "@elizaos/cloud-sdk": "workspace:*",
    "@elizaos/core": "workspace:*",
    "@elizaos/plugin-cloud-apps": "workspace:*",
    "@elizaos/plugin-elizacloud": "workspace:*",
    "@elizaos/plugin-elevenlabs": "workspace:*",
    "@elizaos/plugin-sql": "workspace:*",
    "@elizaos/security": "workspace:*",
    "@elizaos/shared": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@octokit/rest": "^22.0.1",
    "@sendgrid/mail": "^8.1.6",
    "@solana/kit": "^6.0.0",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "1.98.4",
    "@stwd/sdk": "^0.11.0",
    "@upstash/redis": "^1.37.0",
    "@x402/svm": "2.11.0",
    "ai": "^6.0.170",
    "ajv": "^8.20.0",
    "bs58": "^6.0.0",
    "decimal.js": "^10.6.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "exceljs": "^4.4.0",
    "expletives": "^0.1.5",
    "gray-matter": "^4.0.3",
    "hono": "4.12.25",
    "jose": "^6.0.0",
    "json-schema": "^0.4.0",
    "json5": "^2.2.3",
    "libphonenumber-js": "^1.12.42",
    "nanoid": "^5.1.9",
    "nodemailer": "^9.0.1",
    "pg": "^8.20.0",
    "redis": "^5.0.0",
    "ssh2": "^1.17.0",
    "stripe": "^22.0.0",
    "telegraf": "^4.16.3",
    "tweetnacl": "^1.0.3",
    "twitter-api-v2": "^1.29.0",
    "uuid": "^14.0.0",
    "viem": "^2.48.8",
    "wadis": "^1.0.2",
    "ws": "^8.20.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@cloudflare/workers-types": "^4.20260429.1",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/ssh2": "^1.15.5",
    "@types/ws": "^8.18.1",
    "bun-types": "^1.3.13",
    "drizzle-kit": "^0.31.10",
    "ioredis-mock": "^8.13.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
