{
  "name": "@elizaos/cloud-routing",
  "version": "2.0.3-beta.7",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc --noCheck -p tsconfig.json && node ../../scripts/prepare-package-dist.mjs packages/cloud/routing",
    "clean": "rm -rf dist",
    "prepack": "bun run build",
    "test": "vitest run src",
    "typecheck": "tsgo --noEmit -p tsconfig.json",
    "lint": "bunx @biomejs/biome check --write --unsafe src",
    "lint:check": "bunx @biomejs/biome check src",
    "format": "bunx @biomejs/biome format --write src",
    "format:check": "bunx @biomejs/biome format src"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@types/node": "^25.0.0",
    "bun-types": "^1.3.12",
    "fast-check": "^4.8.0",
    "vitest": "^4.1.7",
    "typescript": "^6.0.3"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "eliza-source": {
        "types": "./src/index.ts",
        "import": "./src/index.ts",
        "default": "./src/index.ts"
      },
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "elizaos": {
    "scripts": {
      "coreBuild": true
    }
  }
}
