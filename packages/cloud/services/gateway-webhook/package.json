{
  "name": "@elizaos/gateway-webhook",
  "version": "1.0.0",
  "description": "Multi-platform webhook gateway for Eliza Cloud (Telegram, Blooio, Twilio, WhatsApp)",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "lint": "bunx @biomejs/biome check --write --unsafe .",
    "lint:check": "bunx @biomejs/biome check .",
    "lint:fix": "bunx @biomejs/biome check --write --unsafe .",
    "format": "bunx @biomejs/biome format --write .",
    "format:check": "bunx @biomejs/biome format .",
    "dev": "PORT=3002 bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target node",
    "clean": "rm -rf dist",
    "start": "PORT=3002 bun run src/index.ts",
    "typecheck": "tsgo --noEmit",
    "test": "bun test",
    "docker:build": "docker build -t gateway-webhook:local ."
  },
  "dependencies": {
    "@elizaos/cloud-services-common": "workspace:*",
    "@upstash/redis": "^1.37.0",
    "hashring": "^3.2.0",
    "hono": "4.12.25",
    "ioredis": "^5.10.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@types/hashring": "^3.2.5",
    "@types/node": "22.19.17",
    "bun-types": "1.3.14",
    "ioredis-mock": "^8.13.1",
    "typescript": "^6.0.3"
  }
}
