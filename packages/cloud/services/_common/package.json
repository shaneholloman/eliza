{
  "name": "@elizaos/cloud-services-common",
  "version": "1.0.0",
  "description": "Shared utilities for cloud-services packages (structured logger, k8s service-account helpers).",
  "type": "module",
  "private": true,
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./logger": "./src/logger.ts",
    "./k8s-service-account": "./src/k8s-service-account.ts"
  },
  "scripts": {
    "typecheck": "tsgo --noEmit",
    "test": "bun test tests",
    "lint": "bunx @biomejs/biome check --write --unsafe .",
    "lint:check": "bunx @biomejs/biome check .",
    "lint:fix": "bunx @biomejs/biome check --write --unsafe .",
    "format": "bunx @biomejs/biome format --write .",
    "format:check": "bunx @biomejs/biome format ."
  },
  "devDependencies": {
    "@types/node": "22.19.17",
    "bun-types": "1.3.14",
    "typescript": "^6.0.3"
  }
}
