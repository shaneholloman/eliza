{
  "name": "Eliza",
  "short_name": "Eliza",
  "description": "Your agent, everywhere. Desktop, mobile, and cloud, all running the same Eliza.",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#160d07",
  "theme_color": "#160d07",
  "icons": [
    {
      "src": "/brand/favicons/favicon.svg",
