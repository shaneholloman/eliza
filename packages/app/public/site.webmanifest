    {
      "src": "/brand/favicons/favicon.ico",
      "sizes": "any",
      "type": "image/x-icon"
    },
    {
      "src": "/brand/favicons/android-chrome-192x192.png",
      "sizes": "192x192",
      "type": "image/png"
    },
    {
      "src": "/brand/favicons/android-chrome-512x512.png",
      "sizes": "512x512",
      "type": "image/png"
    }
  ]
}
