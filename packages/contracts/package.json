{
  "name": "@elizaos/contracts",
  "version": "2.0.3-beta.7",
  "description": "Pure type contracts extracted from @elizaos/core — types only, no runtime.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "eliza-source": {
        "types": "./src/index.ts",
        "import": "./src/index.ts",
        "default": "./src/index.ts"
      },
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./*.css": "./dist/*.css",
    "./*": {
      "types": "./dist/*.d.ts",
      "eliza-source": {
        "types": "./src/*.ts",
        "import": "./src/*.ts",
        "default": "./src/*.ts"
      },
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc --noCheck -p tsconfig.build.json",
    "test": "vitest run --config ./vitest.config.ts",
    "typecheck": "tsgo --noEmit",
    "lint": "bunx @biomejs/biome check --write --unsafe .",
    "lint:check": "bunx @biomejs/biome check .",
    "format": "bunx @biomejs/biome format --write .",
    "format:check": "bunx @biomejs/biome format .",
    "clean": "node ../scripts/rm-path-recursive.mjs dist"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@types/node": "^25.1.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "elizaos": {
    "scripts": {
      "coreBuild": true
    }
  }
}
