{
  "name": "@elizaos/soc2-verify",
  "version": "0.1.0",
  "description": "SOC2 control-verification harness. Runs static and dynamic checks against the Eliza monorepo and emits a JSON+Markdown evidence report for auditor sampling.",
  "type": "module",
  "license": "MIT",
  "private": true,
  "homepage": "https://github.com/elizaOS/eliza",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elizaOS/eliza.git",
    "directory": "packages/security/soc2-verify"
  },
  "keywords": [
    "elizaos",
    "soc2",
    "compliance",
    "audit",
    "evidence",
    "verification"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./cli": "./src/cli.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "verify": "bun run src/cli.ts",
    "verify:strict": "bun run src/cli.ts --strict-fail",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsgo --noEmit -p tsconfig.json",
    "lint": "bunx @biomejs/biome check --write --unsafe .",
    "lint:check": "bunx @biomejs/biome check .",
    "lint:fix": "bunx @biomejs/biome check --write --unsafe .",
    "format": "bunx @biomejs/biome format --write .",
    "format:check": "bunx @biomejs/biome format ."
  },
  "dependencies": {
    "@elizaos/security": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.0.0"
  }
}
