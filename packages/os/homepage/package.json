{
  "name": "@elizaos/os-homepage",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --bun vite",
    "build": "bun --bun vite build",
    "deploy": "bunx wrangler pages deploy dist --project-name elizaos-homepage --branch main",
    "preview": "bun --bun vite preview --port 4455",
    "typecheck": "tsc -b",
    "test": "node --test tests/smoke.node.test.mjs",
    "test:e2e": "../../../node_modules/.bin/playwright test",
    "screenshots": "node scripts/capture-screenshots.mjs",
    "lint": "bunx @biomejs/biome check --write --unsafe .",
    "lint:check": "bunx @biomejs/biome check .",
    "format": "bunx @biomejs/biome format --write .",
    "format:check": "bunx @biomejs/biome format .",
    "predev": "node ../../shared/scripts/sync-to-public.mjs ./public --logos --ogembeds --concepts --background --background-videos",
    "prebuild": "node ../../shared/scripts/sync-to-public.mjs ./public --logos --ogembeds --concepts --background --background-videos",
    "clean": "node ../../scripts/rm-path-recursive.mjs dist"
  },
  "dependencies": {
    "@elizaos/ui": "workspace:*",
    "@fontsource/poppins": "^5.2.7",
    "@stwd/sdk": "^0.10.1",
    "@tailwindcss/vite": "^4.3.1",
    "@vitejs/plugin-react": "^6.0.0",
    "lucide-react": "^1.0.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "vite": "^8.0.0",
    "@elizaos/shared": "workspace:*"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@types/node": "^24.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "playwright": "^1.59.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "sharp": "^0.34.5",
    "typescript": "^6.0.3",
    "viem": "^2.48.8"
  }
}
