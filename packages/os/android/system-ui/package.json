{
  "name": "@elizaos/os-android-system-ui",
  "version": "0.1.0",
  "private": true,
  "description": "Unified system UI scaffolding for the elizaOS AOSP fork. Replaces SystemUI.apk surfaces (status bar, lock screen, nav buttons) when fully integrated.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "typecheck": "tsgo --noEmit -p tsconfig.json",
    "test": "vitest run --config ./vitest.config.ts",
    "lint": "bunx @biomejs/biome check --write --unsafe .",
    "lint:check": "bunx @biomejs/biome check .",
    "lint:fix": "bunx @biomejs/biome check --write --unsafe .",
    "format": "bunx @biomejs/biome format --write .",
    "format:check": "bunx @biomejs/biome format ."
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@elizaos/os-shared-system": "workspace:*",
    "@elizaos/ui": "workspace:*"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.0.0 || ^19.0.0",
    "@types/react-dom": "^18.0.0 || ^19.0.0",
    "jsdom": "^29.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.18"
  }
}
