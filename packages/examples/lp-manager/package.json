{
  "name": "@elizaos/example-lp-manager",
  "version": "2.0.0-beta.0",
  "type": "module",
  "description": "Autonomous LP management agent for Solana and EVM DEXes with automatic rebalancing",
  "scripts": {
    "start": "bun run src/agent.ts",
    "dev": "bun --watch run src/agent.ts",
    "test": "bun test smoke.test.js",
    "test:watch": "bun test --watch",
    "lint": "bunx @biomejs/biome check --write --unsafe .",
    "lint:check": "bunx @biomejs/biome check .",
    "format": "bunx @biomejs/biome format --write .",
    "format:check": "bunx @biomejs/biome format .",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@elizaos/core": "workspace:*",
    "@elizaos/plugin-wallet": "workspace:*",
    "@elizaos/plugin-sql": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
