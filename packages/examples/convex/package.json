{
  "name": "@elizaos/example-convex",
  "version": "2.0.0-beta.0",
  "description": "elizaOS agent running on Convex — messages processed via messageService.handleMessage with real-time persistence",
  "type": "module",
  "scripts": {
    "dev": "convex dev",
    "start": "convex dev",
    "test": "bun run test-client.ts --once",
    "deploy": "convex deploy",
    "lint": "bunx @biomejs/biome check --write --unsafe .",
    "lint:check": "bunx @biomejs/biome check .",
    "format": "bunx @biomejs/biome format --write .",
    "format:check": "bunx @biomejs/biome format .",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@elizaos/core": "workspace:*",
    "@elizaos/plugin-openai": "workspace:*",
    "@elizaos/plugin-anthropic": "workspace:*",
    "@elizaos/plugin-google-genai": "workspace:*",
    "@elizaos/plugin-sql": "workspace:*",
    "convex": "^1.25.2",
    "dotenv": "^17.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
