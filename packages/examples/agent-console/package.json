{
  "name": "@elizaos/example-agent-console",
  "version": "2.0.0-beta.0",
  "description": "Live observability dashboard for an elizaOS AgentRuntime — every stage, prompt, tool call, and event in real time.",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "bun run server.ts",
    "dev": "bun --hot run server.ts",
    "test": "bun test action-scanner.test.ts",
    "typecheck": "tsgo --noEmit -p tsconfig.json",
    "format": "bunx @biomejs/biome format --write .",
    "format:check": "bunx @biomejs/biome format ."
  },
  "dependencies": {
    "@elizaos/core": "workspace:*",
    "@elizaos/plugin-openai": "workspace:*",
    "@elizaos/plugin-sql": "workspace:*",
    "typescript": "^6.0.3",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "bun-types": "1.3.14"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
