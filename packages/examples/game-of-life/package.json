{
  "name": "@elizaos/example-game-of-life",
  "version": "2.0.0-beta.0",
  "description": "Agentic Game of Life - multi-agent evolution simulation with self-replicating agents",
  "type": "module",
  "scripts": {
    "start": "bun run game.ts",
    "dev": "bun run game.ts --fast --stats",
    "fast": "bun run game.ts --fast",
    "stats": "bun run game.ts --stats",
    "test": "bun run game.ts --fast --agents=2 --ticks=3",
    "lint": "bunx @biomejs/biome check --write --unsafe .",
    "lint:check": "bunx @biomejs/biome check .",
    "format": "bunx @biomejs/biome format --write .",
    "format:check": "bunx @biomejs/biome format .",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@elizaos/core": "workspace:*",
    "@elizaos/plugin-inmemorydb": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
