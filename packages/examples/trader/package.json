{
  "name": "@elizaos/example-trader-ts",
  "version": "2.0.0-beta.0",
  "type": "module",
  "scripts": {
    "dev": "bun --bun vite",
    "build": "tsc && bun --bun vite build",
    "clean": "rm -rf dist",
    "preview": "bun --bun vite preview",
    "test": "bun test",
    "lint": "bunx @biomejs/biome check --write --unsafe .",
