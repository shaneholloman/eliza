{
  "name": "eliza-react-example",
  "version": "2.0.0-beta.0",
  "type": "module",
  "scripts": {
    "predev": "node scripts/copy-pglite-assets.mjs",
    "dev": "bun --bun vite",
    "prebuild": "node scripts/copy-pglite-assets.mjs",
    "build": "tsc && bun --bun vite build",
    "clean": "rm -rf dist",
    "prepreview": "node scripts/copy-pglite-assets.mjs",
    "preview": "bun --bun vite preview",
    "test": "bun test",
    "lint": "bunx @biomejs/biome check --write --unsafe .",
    "lint:check": "bunx @biomejs/biome check .",
    "typecheck": "tsgo --noEmit",
    "format": "bunx @biomejs/biome format --write .",
    "format:check": "bunx @biomejs/biome format ."
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.4.0",
    "@elizaos/core": "workspace:*",
    "@elizaos/plugin-anthropic": "workspace:*",
    "@elizaos/plugin-elizacloud": "workspace:*",
    "@elizaos/plugin-openai": "workspace:*",
    "@elizaos/plugin-openrouter": "workspace:*",
    "@elizaos/plugin-sql": "workspace:*",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/react": "19.2.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.8"
  }
}
