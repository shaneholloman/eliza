{
  "name": "@elizaos/example-app-electron-workspace",
  "type": "module",
  "version": "2.0.0-beta.0",
  "scripts": {
    "dev:renderer": "bun run --cwd frontend dev",
    "dev:electron": "bun run --cwd backend dev",
    "build:renderer": "bun run --cwd frontend build",
    "start": "bun run --cwd backend start",
    "test": "bun test smoke.test.js && bun run --cwd frontend test",
    "lint": "bunx @biomejs/biome check --write --unsafe .",
    "lint:check": "bunx @biomejs/biome check .",
    "format": "bunx @biomejs/biome format --write .",
    "format:check": "bunx @biomejs/biome format ."
  }
}
