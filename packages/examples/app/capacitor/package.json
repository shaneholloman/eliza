{
  "name": "@elizaos/example-app-capacitor",
  "version": "2.0.0-beta.0",
  "type": "module",
  "scripts": {
    "dev:backend": "bun run --cwd backend dev",
    "dev:frontend": "bun run --cwd frontend dev",
    "build:frontend": "bun run --cwd frontend build",
    "cap:sync": "bunx cap sync",
    "test": "bun test smoke.test.js && bun run --cwd frontend test",
    "lint": "bunx @biomejs/biome check --write --unsafe .",
    "lint:check": "bunx @biomejs/biome check .",
    "format": "bunx @biomejs/biome format --write .",
    "format:check": "bunx @biomejs/biome format ."
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.4",
    "typescript": "^6.0.3"
  }
}
