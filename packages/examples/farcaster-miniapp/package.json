{
  "name": "eliza-multichain-miniapp",
  "version": "2.0.0-beta.0",
  "type": "module",
  "description": "ElizaOS Multi-chain Trading Platform - Farcaster Mini App",
  "scripts": {
    "dev": "bun --bun vite",
    "build": "tsc && bun --bun vite build",
    "clean": "rm -rf dist",
    "preview": "bun --bun vite preview",
    "start": "node server.js",
    "test": "bun test",
    "lint": "bunx @biomejs/biome check --write --unsafe .",
    "lint:check": "bunx @biomejs/biome check .",
    "typecheck": "tsgo --noEmit",
    "format": "bunx @biomejs/biome format --write .",
    "format:check": "bunx @biomejs/biome format ."
  },
  "dependencies": {
    "@farcaster/miniapp-sdk": "^0.3.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/react": "^19.2.3",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "typescript": "5.8.3",
    "vite": "^8.0.8"
  }
}
