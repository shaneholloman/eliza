{
  "compilerOptions": {
    "target": "es2023",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "lib": ["ES2023", "DOM"],
    "types": ["node"],
    "paths": {
      "@elizaos/core": ["../core/src/index.node.ts"],
      "@elizaos/core/testing": ["../core/src/testing/index.ts"],
      "@elizaos/agent": ["../agent/src/index.ts"],
      "@elizaos/auth": ["../auth/src/index.ts"],
      "@elizaos/auth/*": ["../auth/src/*"],
      "@elizaos/shared": ["../shared/src/index.ts"],
      "@elizaos/logger": ["../logger/src/index.ts"],
      "@elizaos/security": ["../security/src/index.ts"],
      "@elizaos/security/*": ["../security/src/*"],
      "@elizaos/contracts": ["../contracts/src/index.ts"],
      "@elizaos/vault": ["../vault/src/index.ts"],
      "@elizaos/cloud-routing": ["../cloud/routing/src/index.ts"],
      "@elizaos/cloud-routing/*": ["../cloud/routing/src/*"],
      "@elizaos/app-core": ["../app-core/src/index.ts"],
      "@elizaos/app-core/*": ["../app-core/src/*"],
      "@elizaos/ui": ["../ui/src/index.ts"],
      "@elizaos/ui/*": ["../ui/src/*"],
      "@elizaos/import-conversations": ["../import-conversations/src/index.ts"],
      "@elizaos/import-conversations/*": ["../import-conversations/src/*"],
      "@elizaos/import-conversations/browser": ["../import-conversations/src/browser.ts"],
      "@elizaos/skills": ["../skills/src/index.ts"],
      "@elizaos/skills/*": ["../skills/src/*"],
      "@elizaos/plugin-browser": ["../../plugins/plugin-browser/src/index.ts"],
      "@elizaos/plugin-browser/*": ["../../plugins/plugin-browser/src/*"],
      "@elizaos/plugin-capacitor-bridge": [
        "../../plugins/plugin-capacitor-bridge/src/index.ts"
      ],
      "@elizaos/plugin-capacitor-bridge/*": [
        "../../plugins/plugin-capacitor-bridge/src/*"
      ],
      "@elizaos/plugin-coding-tools": [
        "../../plugins/plugin-coding-tools/src/index.ts"
      ],
      "@elizaos/plugin-coding-tools/*": [
        "../../plugins/plugin-coding-tools/src/*"
      ],
      "@elizaos/plugin-elizacloud": [
        "../../plugins/plugin-elizacloud/dist/node/index.d.ts"
      ],
      "@elizaos/plugin-agent-skills": [
        "../../plugins/plugin-agent-skills/src/index.ts"
      ],
      "@elizaos/plugin-agent-orchestrator": [
        "../../plugins/plugin-agent-orchestrator/src/index.ts"
      ],
      "@elizaos/plugin-app-control": [
        "../../plugins/plugin-app-control/src/index.ts"
      ],
      "@elizaos/plugin-app-control/*": [
        "../../plugins/plugin-app-control/src/*"
      ],
      "@elizaos/plugin-app-manager": [
        "../../plugins/plugin-app-manager/src/index.ts"
      ],
      "@elizaos/plugin-remote-manifest": [
        "../plugin-remote-manifest/src/index.ts"
      ],
      "@elizaos/plugin-remote-manifest/*": ["../plugin-remote-manifest/src/*"],
      "@elizaos/plugin-worker-runtime": [
        "../plugin-worker-runtime/src/index.ts"
      ],
      "@elizaos/plugin-worker-runtime/*": ["../plugin-worker-runtime/src/*"],
      "@elizaos/plugin-commands": ["../../plugins/plugin-commands/index.ts"],
      "@elizaos/plugin-native-filesystem": [
        "../../plugins/plugin-native-filesystem/src/index.ts"
      ],
      "@elizaos/plugin-github": ["../../plugins/plugin-github/src/index.ts"],
      "@elizaos/plugin-gitpathologist": [
        "../../plugins/plugin-gitpathologist/src/index.ts"
      ],
      "@elizaos/plugin-local-inference": [
        "../../plugins/plugin-local-inference/src/index.ts"
      ],
      "@elizaos/plugin-shell": ["../../plugins/plugin-shell/src/index.ts"],
      "@elizaos/plugin-sql": ["../../plugins/plugin-sql/src/index.ts"],
      "@elizaos/plugin-telegram": [
        "../../plugins/plugin-telegram/src/index.ts"
      ],
      "@elizaos/plugin-signal": ["../../plugins/plugin-signal/src/index.ts"],
      "@elizaos/plugin-streaming": [
        "../../plugins/plugin-streaming/src/index.ts"
      ],
      "@elizaos/plugin-mcp": ["../../plugins/plugin-mcp/src/index.ts"],
      "@elizaos/plugin-mcp/*": ["../../plugins/plugin-mcp/src/*"],
      "@elizaos/plugin-todos": ["../../plugins/plugin-todos/src/index.ts"],
      "@elizaos/plugin-todos/*": ["../../plugins/plugin-todos/src/*"],
      "@elizaos/plugin-video": ["../../plugins/plugin-video/src/index.ts"],
      "@elizaos/plugin-workflow": [
        "../../plugins/plugin-workflow/src/index.ts"
      ],
      "@elizaos/plugin-facewear": [
        "../../plugins/plugin-facewear/src/index.ts"
      ],
      "@elizaos/capacitor-appblocker": [
        "../../plugins/plugin-native-appblocker/src/index.ts"
      ],
      "@elizaos/capacitor-contacts": [
        "../../plugins/plugin-native-contacts/src/index.ts"
      ],
      "@elizaos/capacitor-messages": [
        "../../plugins/plugin-native-messages/src/index.ts"
      ],
      "@elizaos/capacitor-mobile-signals": [
        "../../plugins/plugin-native-mobile-signals/src/index.ts"
      ],
      "@elizaos/capacitor-phone": [
        "../../plugins/plugin-native-phone/src/index.ts"
      ],
      "@elizaos/capacitor-system": [
        "../../plugins/plugin-native-system/src/index.ts"
      ]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts"]
}
