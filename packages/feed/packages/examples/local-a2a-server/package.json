{
  "name": "@feed/local-a2a-server",
  "version": "0.1.0",
  "description": "Standalone A2A server for local agent development",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "bun run --watch src/server.ts",
    "build": "bun build --target=bun --outfile dist/index.js src/server.ts",
    "start": "bun run src/server.ts",
    "test": "bun test tests",
    "typecheck": "bun run tsc -p . --noEmit",
    "lint": "cd ../../.. && bunx @biomejs/biome check --write --unsafe --config-path ../../biome.json --files-ignore-unknown=true --no-errors-on-unmatched packages/examples/local-a2a-server/package.json packages/examples/local-a2a-server/tsconfig.json",
    "lint:check": "cd ../../.. && bunx @biomejs/biome check --config-path ../../biome.json --files-ignore-unknown=true --no-errors-on-unmatched packages/examples/local-a2a-server/package.json packages/examples/local-a2a-server/tsconfig.json",
    "lint:fix": "cd ../../.. && bunx @biomejs/biome check --write --unsafe --config-path ../../biome.json --files-ignore-unknown=true --no-errors-on-unmatched packages/examples/local-a2a-server/package.json packages/examples/local-a2a-server/tsconfig.json",
    "format": "cd ../../.. && bunx @biomejs/biome format --write --config-path ../../biome.json --files-ignore-unknown=true packages/examples/local-a2a-server/package.json packages/examples/local-a2a-server/tsconfig.json",
    "format:check": "cd ../../.. && bunx @biomejs/biome format --config-path ../../biome.json --files-ignore-unknown=true packages/examples/local-a2a-server/package.json packages/examples/local-a2a-server/tsconfig.json",
    "clean": "node ../../../../../packages/scripts/rm-path-recursive.mjs dist"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "ethers": "^6.16.0",
    "express": "^4.21.2",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.10",
    "typescript": "^5.9.3",
    "vitest": "4.1.9"
  }
}
