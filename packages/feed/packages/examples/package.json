{
  "name": "@feed/examples",
  "version": "0.1.0",
  "private": true,
  "description": "Feed A2A example agents, training harness, and local development server",
  "scripts": {
    "start": "./scripts/start-all.sh",
    "stop": "./scripts/stop-all.sh",
    "demo": "./scripts/demo-all-actions.sh",
    "agent:ts": "./scripts/run-typescript-agent.sh",
    "agent:py": "cd feed-langgraph-agent && uv run python local_agent.py",
    "server": "cd local-a2a-server && bun run dev",
    "test:ts": "cd feed-typescript-agent && bun test tests/local-e2e.test.ts",
    "test:py": "cd feed-langgraph-agent && uv run pytest tests/test_local_agent.py -v",
    "harness": "cd harness && bun run src/cli.ts",
    "harness:train": "cd harness && bun run src/cli.ts train",
    "harness:test": "cd harness && bun test",
    "lint": "cd ../.. && bunx @biomejs/biome check --write --unsafe --config-path ../../biome.json --files-ignore-unknown=true --no-errors-on-unmatched packages/examples/package.json packages/examples/README.md",
    "lint:check": "cd ../.. && bunx @biomejs/biome check --config-path ../../biome.json --files-ignore-unknown=true --no-errors-on-unmatched packages/examples/package.json packages/examples/README.md",
    "lint:fix": "cd ../.. && bunx @biomejs/biome check --write --unsafe --config-path ../../biome.json --files-ignore-unknown=true --no-errors-on-unmatched packages/examples/package.json packages/examples/README.md",
    "format": "cd ../.. && bunx @biomejs/biome format --write --config-path ../../biome.json --files-ignore-unknown=true packages/examples/package.json packages/examples/README.md",
    "format:check": "cd ../.. && bunx @biomejs/biome format --config-path ../../biome.json --files-ignore-unknown=true packages/examples/package.json packages/examples/README.md",
    "test": "bun run test:ts && bun run harness:test"
  },
  "workspaces": [
    "local-a2a-server",
    "feed-typescript-agent",
    "feed-langgraph-agent",
    "harness"
  ]
}
