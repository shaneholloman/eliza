{
  "name": "@feed/contracts",
  "version": "0.1.0",
  "private": true,
  "description": "Smart contract types and deployment information for Feed",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./src/index.ts"
    },
    "./deployments/local": {
      "types": "./deployments/local/index.ts",
      "import": "./deployments/local/index.ts",
      "require": "./deployments/local/index.ts"
    },
    "./deployments/base-sepolia": {
      "types": "./deployments/base-sepolia/index.ts",
      "import": "./deployments/base-sepolia/index.ts",
      "require": "./deployments/base-sepolia/index.ts"
    },
    "./deployments/base": {
      "types": "./deployments/base/index.ts",
      "import": "./deployments/base/index.ts",
      "require": "./deployments/base/index.ts"
    }
  },
  "files": [
    "src",
    "deployments"
  ],
  "scripts": {
    "lint": "cd ../.. && bunx @biomejs/biome check --write --unsafe --config-path ../../biome.json --files-ignore-unknown=true --no-errors-on-unmatched packages/contracts/package.json packages/contracts/tsconfig.json",
    "typecheck": "cd ../.. && bun run scripts/typecheck-workspace.ts packages/contracts",
    "build": "bash ./bootstrap-dependencies.sh && forge build",
    "test": "bash ./bootstrap-dependencies.sh && forge test -vvv",
    "test:unit": "forge test --match-path 'test/*.t.sol' --no-match-path 'test/Fuzz*.sol' --no-match-path 'test/Invariant*.sol' -vvv",
    "test:fuzz": "forge test --match-path 'test/Fuzz*.sol' -vvv",
    "test:invariant": "forge test --match-path 'test/Invariant*.sol' -vvv",
    "test:all": "forge test -vvv && bun run slither",
    "test:coverage": "forge coverage --report lcov",
    "slither": "slither . --config-file slither.config.json --checklist",
    "slither:triage": "slither . --config-file slither.config.json --triage-mode",
    "security": "bun run test && bun run slither",
    "security:full": "bun run test:all && bun run test:fuzz && bun run test:invariant",
    "lint:check": "cd ../.. && bunx @biomejs/biome check --config-path ../../biome.json --files-ignore-unknown=true --no-errors-on-unmatched packages/contracts/package.json packages/contracts/tsconfig.json",
    "lint:fix": "cd ../.. && bunx @biomejs/biome check --write --unsafe --config-path ../../biome.json --files-ignore-unknown=true --no-errors-on-unmatched packages/contracts/package.json packages/contracts/tsconfig.json",
    "format": "cd ../.. && bunx @biomejs/biome format --write --config-path ../../biome.json --files-ignore-unknown=true packages/contracts/package.json packages/contracts/tsconfig.json",
    "format:check": "cd ../.. && bunx @biomejs/biome format --config-path ../../biome.json --files-ignore-unknown=true packages/contracts/package.json packages/contracts/tsconfig.json",
    "clean": "forge clean"
  },
  "dependencies": {
    "@feed/shared": "workspace:*"
  },
  "peerDependencies": {
    "ethers": "^6.16.0",
    "viem": "^2.45.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "hardhat-preprocessor": "^0.1.5",
    "typescript": "^5.9.3"
  }
}
