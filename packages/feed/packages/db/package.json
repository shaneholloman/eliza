{
  "name": "@feed/db",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "Feed Database Layer - Drizzle ORM",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": {
      "types": "./src/schema/index.ts",
      "import": "./src/schema/index.ts",
      "require": "./src/schema/index.ts"
    },
    "./types": {
      "types": "./src/types.ts",
      "import": "./src/types.ts",
      "require": "./src/types.ts"
    }
  },
  "scripts": {
    "lint": "cd ../.. && bunx @biomejs/biome check --write --unsafe --config-path ../../biome.json --files-ignore-unknown=true --no-errors-on-unmatched packages/db/package.json packages/db/tsconfig.json",
    "typecheck": "cd ../.. && bun run tsc -p packages/db --noEmit",
    "db:generate": "drizzle-kit generate --config=drizzle.config.cjs",
    "db:migrate": "drizzle-kit migrate --config=drizzle.config.cjs",
    "db:push": "drizzle-kit push --config=drizzle.config.cjs",
    "db:pull": "drizzle-kit pull --config=drizzle.config.cjs",
    "db:studio": "drizzle-kit studio --config=drizzle.config.cjs",
    "db:check": "drizzle-kit check --config=drizzle.config.cjs",
    "db:sync-migrations": "tsx scripts/sync-migrations.ts",
    "lint:check": "cd ../.. && bunx @biomejs/biome check --config-path ../../biome.json --files-ignore-unknown=true --no-errors-on-unmatched packages/db/package.json packages/db/tsconfig.json",
    "lint:fix": "cd ../.. && bunx @biomejs/biome check --write --unsafe --config-path ../../biome.json --files-ignore-unknown=true --no-errors-on-unmatched packages/db/package.json packages/db/tsconfig.json",
    "format": "cd ../.. && bunx @biomejs/biome format --write --config-path ../../biome.json --files-ignore-unknown=true packages/db/package.json packages/db/tsconfig.json",
    "format:check": "cd ../.. && bunx @biomejs/biome format --config-path ../../biome.json --files-ignore-unknown=true packages/db/package.json packages/db/tsconfig.json"
  },
  "dependencies": {
    "@feed/shared": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.7"
  },
  "peerDependencies": {
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.7"
  },
  "devDependencies": {
    "@elizaos/plugin-sql": "2.0.0-alpha.17",
    "@types/node": "^24.10.0",
    "drizzle-kit": "^0.31.8",
    "tsx": "^4.19.4",
    "typescript": "^5.9.3"
  }
}
