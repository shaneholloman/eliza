{
  "name": "@feed/agents",
  "version": "0.1.0",
  "private": true,
  "description": "Feed Agent System - AI agents, plugins, and services",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./src/index.ts"
    },
    "./client": {
      "types": "./src/client.ts",
      "import": "./src/client.ts",
      "require": "./src/client.ts"
    },
    "./training": {
      "types": "./src/training/index.ts",
      "import": "./src/training/index.ts",
      "require": "./src/training/index.ts"
    },
    "./rubrics": {
      "types": "./src/rubrics/index.ts",
      "import": "./src/rubrics/index.ts",
      "require": "./src/rubrics/index.ts"
    },
    "./rubrics/index": {
      "types": "./src/rubrics/index.ts",
      "import": "./src/rubrics/index.ts",
      "require": "./src/rubrics/index.ts"
    }
  },
  "scripts": {
    "lint": "cd ../.. && bunx @biomejs/biome check --write --unsafe --config-path ../../biome.json --files-ignore-unknown=true --no-errors-on-unmatched packages/agents/package.json packages/agents/tsconfig.json",
    "typecheck": "cd ../.. && bun run tsc -p packages/agents --noEmit",
    "lint:check": "cd ../.. && bunx @biomejs/biome check --config-path ../../biome.json --files-ignore-unknown=true --no-errors-on-unmatched packages/agents/package.json packages/agents/tsconfig.json",
    "lint:fix": "cd ../.. && bunx @biomejs/biome check --write --unsafe --config-path ../../biome.json --files-ignore-unknown=true --no-errors-on-unmatched packages/agents/package.json packages/agents/tsconfig.json",
    "format": "cd ../.. && bunx @biomejs/biome format --write --config-path ../../biome.json --files-ignore-unknown=true packages/agents/package.json packages/agents/tsconfig.json",
    "format:check": "cd ../.. && bunx @biomejs/biome format --config-path ../../biome.json --files-ignore-unknown=true packages/agents/package.json packages/agents/tsconfig.json"
  },
  "dependencies": {
    "@elizaos/core": "2.0.0-alpha.109",
    "@ai-sdk/groq": "^3.0.39",
    "@ai-sdk/openai-compatible": "^2.0.51",
    "@vercel/blob": "2.3.2",
    "@feed/a2a": "workspace:*",
    "@feed/db": "workspace:*",
    "@feed/shared": "workspace:*",
    "ai": "6.0.207",
    "js-tiktoken": "^1.0.21",
    "posthog-node": "^5.17.0"
  },
  "peerDependencies": {
    "@a2a-js/sdk": "^0.3.5",
    "@ai-sdk/groq": "^3.0.39",
    "@anthropic-ai/sdk": "^0.71.0",
    "@feed/api": "workspace:*",
    "@feed/core": "workspace:*",
    "@feed/db": "workspace:*",
    "@feed/engine": "workspace:*",
    "@feed/shared": "workspace:*",
    "@elizaos/core": "2.0.0-alpha.109",
    "@elizaos/plugin-anthropic": "2.0.0-alpha.11",
    "@elizaos/plugin-openai": "2.0.0-alpha.15",
    "@huggingface/hub": "^2.6.12",
    "@privy-io/server-auth": "^1.32.5",
    "ai": "6.0.207",
    "drizzle-orm": "^0.44.7",
    "graphql-request": "^7.2.0",
    "ioredis": "^5.6.1",
    "tiktoken": "^1.0.22",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "bun-types": "^1.3.2",
    "typescript": "^5.9.3"
  }
}
