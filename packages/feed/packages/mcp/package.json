{
  "name": "@feed/mcp",
  "version": "0.1.0",
  "private": true,
  "description": "Feed MCP Protocol - Model Context Protocol server implementation",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./src/index.ts"
    }
  },
  "scripts": {
    "lint": "cd ../.. && bunx @biomejs/biome check --write --unsafe --config-path ../../biome.json --files-ignore-unknown=true --no-errors-on-unmatched packages/mcp/package.json packages/mcp/tsconfig.json",
    "typecheck": "cd ../.. && bun run tsc -p packages/mcp --noEmit",
    "lint:check": "cd ../.. && bunx @biomejs/biome check --config-path ../../biome.json --files-ignore-unknown=true --no-errors-on-unmatched packages/mcp/package.json packages/mcp/tsconfig.json",
    "lint:fix": "cd ../.. && bunx @biomejs/biome check --write --unsafe --config-path ../../biome.json --files-ignore-unknown=true --no-errors-on-unmatched packages/mcp/package.json packages/mcp/tsconfig.json",
    "format": "cd ../.. && bunx @biomejs/biome format --write --config-path ../../biome.json --files-ignore-unknown=true packages/mcp/package.json packages/mcp/tsconfig.json",
    "format:check": "cd ../.. && bunx @biomejs/biome format --config-path ../../biome.json --files-ignore-unknown=true packages/mcp/package.json packages/mcp/tsconfig.json"
  },
  "dependencies": {
    "@feed/shared": "workspace:*",
    "@feed/a2a": "workspace:*",
    "@feed/core": "workspace:*",
    "@feed/engine": "workspace:*"
  },
  "peerDependencies": {
    "@feed/db": "workspace:*",
    "@feed/api": "workspace:*",
    "@feed/engine": "workspace:*",
    "@feed/shared": "workspace:*",
    "@feed/a2a": "workspace:*",
    "drizzle-orm": "^0.44.7",
    "ethers": "^6.15.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "bun-types": "^1.3.2",
    "typescript": "^5.9.3"
  }
}
