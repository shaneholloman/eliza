{
  "name": "@feed/engine",
  "version": "0.1.0",
  "private": true,
  "description": "Feed Game Engine - Core simulation and generation",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "require": "./src/index.ts"
    },
    "./client": {
      "types": "./src/client.ts",
      "import": "./src/client.ts",
      "require": "./src/client.ts"
    },
    "./config/fees": {
      "types": "./src/config/fees.ts",
      "import": "./src/config/fees.ts",
      "require": "./src/config/fees.ts"
    }
  },
  "scripts": {
    "lint": "cd ../.. && bunx @biomejs/biome check --write --unsafe --config-path ../../biome.json --files-ignore-unknown=true --no-errors-on-unmatched packages/engine/package.json packages/engine/tsconfig.json",
    "typecheck": "cd ../.. && bun run tsc -p packages/engine --noEmit",
    "lint:check": "cd ../.. && bunx @biomejs/biome check --config-path ../../biome.json --files-ignore-unknown=true --no-errors-on-unmatched packages/engine/package.json packages/engine/tsconfig.json",
    "lint:fix": "cd ../.. && bunx @biomejs/biome check --write --unsafe --config-path ../../biome.json --files-ignore-unknown=true --no-errors-on-unmatched packages/engine/package.json packages/engine/tsconfig.json",
    "format": "cd ../.. && bunx @biomejs/biome format --write --config-path ../../biome.json --files-ignore-unknown=true packages/engine/package.json packages/engine/tsconfig.json",
    "format:check": "cd ../.. && bunx @biomejs/biome format --config-path ../../biome.json --files-ignore-unknown=true packages/engine/package.json packages/engine/tsconfig.json"
  },
  "dependencies": {
    "@feed/core": "workspace:*",
    "@feed/db": "workspace:*",
    "@feed/pack-default": "workspace:*",
    "@feed/shared": "workspace:*",
    "@fal-ai/client": "^1.8.1",
    "hono": "4.12.25",
    "xml2js": "^0.6.2"
  },
  "peerDependencies": {
    "drizzle-orm": "^0.44.7",
    "openai": "^6.8.1",
    "dotenv": "^16.4.5",
    "tiktoken": "^1.0.21"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "@types/xml2js": "^0.4.14",
    "bun-types": "^1.3.2",
    "typescript": "^5.9.3"
  }
}
