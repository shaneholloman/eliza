{
  "name": "@feed/root",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/examples/*",
    "tools/*",
    "../contracts",
    "../core",
    "../logger",
    "../prompts",
    "../registry",
    "../shared"
  ],
  "scripts": {
    "postinstall": "bun run scripts/postinstall-install-python-deps.ts && bun run scripts/postinstall-agent-frameworks.ts",
    "agent-frameworks:bootstrap": "bun run scripts/postinstall-agent-frameworks.ts",
    "dev": "bun run scripts/pre-dev/pre-dev-local.ts && bun run scripts/dev-wrapper.ts",
    "dev:web": "turbo dev --filter=web",
    "dev:web:staging": "NODE_ENV=development bun --env-file=.env.staging.local run dev:web",
    "dev:web:production": "NODE_ENV=development bun --env-file=.env.production.local run dev:web",
    "vercel:dev:web:staging": "bun run env:pull:staging && bun run dev:web:staging",
    "vercel:dev:web:production": "bun run env:pull:production && bun run dev:web:production",
    "dev:next-only": "turbo dev:next-only --filter=web",
    "env:pull:staging": "vercel env pull --yes .env.staging.local --environment=staging",
    "env:pull:production": "vercel env pull --yes .env.production.local --environment=production",
    "env:audit": "bun run scripts/env-audit.ts",
    "env:audit:check": "bun run scripts/env-audit.ts --check --format=json",
    "env:validate": "bun run scripts/validate-env.ts",
    "env:validate:staging": "bun run scripts/validate-env.ts --profile=staging --env-file=.env.staging.local",
    "env:validate:production": "bun run scripts/validate-env.ts --profile=production --env-file=.env.production.local",
    "build": "bun run scripts/build-workspace.ts",
    "clean": "bun run --cwd apps/web clean && node ../../packages/scripts/rm-path-recursive.mjs node_modules/.cache .turbo",
    "build:staging": "NODE_ENV=production bun --env-file=.env.staging.local run build",
    "build:production": "NODE_ENV=production bun --env-file=.env.production.local run build",
    "start": "turbo start --filter=web",
    "start:local": "NODE_ENV=production bun --env-file=.env run start",
    "start:staging": "NODE_ENV=production bun --env-file=.env.staging.local run start",
    "start:production": "NODE_ENV=production bun --env-file=.env.production.local run start",
    "check": "bunx @biomejs/biome check --write .",
    "lint": "cd . && bunx @biomejs/biome check --write --unsafe --config-path ../../biome.json --files-ignore-unknown=true --no-errors-on-unmatched package.json README.md",
    "typecheck": "bun run scripts/typecheck-workspace.ts packages/shared packages/contracts packages/db packages/core packages/engine packages/sim packages/agents packages/api packages/a2a packages/mcp packages/testing apps/cli apps/mobile apps/web",
    "validate:all": "bun run typecheck && bun run lint",
    "test": "bun run test:unit && bun run test:integration && bun run test:integration:db-lazy",
    "test:unit": "bun run scripts/test-unit-isolated.ts",
    "test:unit:fast": "TEST_CONCURRENCY=8 bun run scripts/test-unit-isolated.ts",
    "test:integration": "bun run scripts/test-integration-with-server.ts",
    "test:integration:all": "RUN_OPTIONAL_INTEGRATION_TESTS=1 bun run scripts/test-integration-with-server.ts",
    "test:integration:live": "RUN_OPTIONAL_INTEGRATION_TESTS=1 RUN_LIVE_LLM_TESTS=1 bun run scripts/test-integration-with-server.ts packages/testing/integration/agent-actions-persistence.integration.test.ts packages/testing/integration/engine-generation-output.test.ts packages/testing/integration/full-agent-tick.test.ts packages/testing/integration/full-production-tick.test.ts packages/testing/integration/trading-and-questions.integration.test.ts",
    "test:integration:agent0": "RUN_OPTIONAL_INTEGRATION_TESTS=1 bun run scripts/test-integration-with-server.ts packages/testing/integration/agent0-sdk.integration.test.ts",
    "test:integration:db-lazy": "bun test packages/testing/integration/db-lazy-connection.integration.test.ts",
    "test:skip-inventory": "bun run scripts/testing-skip-inventory.mjs",
    "test:ci": "bash scripts/ci/run-all-tests.sh",
    "test:e2e": "bun run build && node ../../packages/scripts/rm-path-recursive.mjs packages/testing/node_modules/@playwright packages/testing/node_modules/playwright && bunx playwright test --config packages/testing/playwright.config.ts",
    "miniapp:deploy": "bash scripts/deploy-miniapp.sh",
    "db:generate": "bun run --cwd packages/db db:generate",
    "db:migrate": "bun run --cwd packages/db db:migrate",
    "db:push": "bun run --cwd packages/db db:push",
    "db:pull": "bun run --cwd packages/db db:pull",
    "db:studio": "bun run --cwd packages/db db:studio",
    "db:check": "bun run --cwd packages/db db:check",
    "db:seed": "bun run scripts/seed-database.ts",
    "db:seed:test": "bun run scripts/seed-test-data.ts all",
    "test:chroma": "cd tools/chroma && bun run test",
    "feed": "bun run apps/cli/src/index.ts",
    "hf:collect": "bun run apps/cli/src/index.ts model collect-data",
    "hf:upload": "bun run apps/cli/src/index.ts model upload-dataset",
    "stress-test": "bun run apps/cli/src/index.ts test load",
    "stress-test:a2a": "bun run apps/cli/src/index.ts test a2a",
    "prepare": "husky",
    "docs:generate": "bun scripts/docs/generate_all_docs.ts",
    "skills:generate": "bun run scripts/generate-skills-md.ts",
    "skills:package": "bun run scripts/generate-skills-md.ts --package",
    "characters:generate": "bun run scripts/generate-local-character-sheets.ts",
    "sim:generate": "bun run scripts/generate-simulation-data.ts",
    "pfp:gallery": "bun run scripts/pfp-gallery.ts",
    "pfp:serve": "bun run scripts/pfp-gallery.ts && python3 -m http.server 8899 --directory output/pfp-gallery",
    "pfp:user": "bun run scripts/generate-user-pfps.ts",
    "pfp:avatar": "bun run scripts/generate-avatar-pfps.ts",
    "sim:characters:local": "bun run scripts/run-local-character-simulation.ts",
    "sim:core": "bun run scripts/run-core-world-simulation.ts",
    "export:characters:local": "bun run scripts/export-local-character-trajectories.ts",
    "ruler:init": "ruler init",
    "ruler:apply": "ruler apply",
    "ruler:apply:dry": "ruler apply --dry-run --verbose",
    "ruler:revert": "ruler revert",
    "solana:registration:debug": "bun run scripts/debug-solana-registration.ts",
    "seed:nft-snapshot:csv": "bun run scripts/seed-nft-snapshot-csv.ts",
    "report:feed": "bun run scripts/feed-health.ts",
    "report:markets": "bun run scripts/market-diversity-report.ts",
    "report:markets:health": "bun run scripts/market-health.ts",
    "report:realism": "bun run scripts/market-realism-report.ts",
    "tick:full": "bun run scripts/run-full-tick.ts",
    "report:training-quality": "bun run scripts/training-data-quality.ts",
    "report:training-viz": "bun run scripts/training-data-viz.ts",
    "steward:init": "bun run scripts/steward-init.ts",
    "inspect:context": "bun run scripts/context-inspector.ts",
    "find:duplicates": "bun run scripts/find-duplicates.ts",
    "lint:check": "cd . && bunx @biomejs/biome check --config-path ../../biome.json --files-ignore-unknown=true --no-errors-on-unmatched package.json README.md",
    "lint:fix": "cd . && bunx @biomejs/biome check --write --unsafe --config-path ../../biome.json --files-ignore-unknown=true --no-errors-on-unmatched package.json README.md",
    "format": "cd . && bunx @biomejs/biome format --write --config-path ../../biome.json --files-ignore-unknown=true package.json README.md",
    "format:check": "cd . && bunx @biomejs/biome format --config-path ../../biome.json --files-ignore-unknown=true package.json README.md"
  },
  "dependencies": {
    "@a2a-js/sdk": "^0.3.5",
    "@feed/a2a": "workspace:*",
    "@feed/agents": "workspace:*",
    "@feed/api": "workspace:*",
    "@feed/core": "workspace:*",
    "@feed/db": "workspace:*",
    "@feed/engine": "workspace:*",
    "@feed/mcp": "workspace:*",
    "@feed/shared": "workspace:*",
    "@feed/testing": "workspace:*",
    "@neondatabase/serverless": "^1.0.2",
    "@tailwindcss/postcss": "^4.3.1",
    "abitype": "1.2.3",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.2",
    "eventsource-parser": "^1.1.2",
    "ethers": "^6.16.0",
    "import-in-the-middle": "^3.1.0",
    "ioredis": "5.11.1",
    "js-tiktoken": "^1.0.21",
    "lightweight-charts": "^5.0.9",
    "nanoid": "^5.1.7",
    "openai": "6.33.0",
    "pg": "8.20.0",
    "postgres": "3.4.8",
    "require-in-the-middle": "^8.0.1",
    "robot3": "^0.4.1",
    "server-only": "^0.0.1",
    "tailwindcss": "^4.3.1",
    "viem": "2.47.6",
    "ws": "8.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@fal-ai/client": "^1.9.5",
    "@intellectronica/ruler": "0.3.44",
    "@playwright/test": "1.61.1",
    "@prb/math": "^4.1.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "24.12.0",
    "baseline-browser-mapping": "^2.9.19",
    "bun-types": "1.3.14",
    "concurrently": "^10.0.3",
    "csv-parse": "^7.0.0",
    "diff": "^9.0.0",
    "hardhat": "3.9.1",
    "husky": "^9.1.7",
    "knip": "^6.14.1",
    "lint-staged": "^17.0.5",
    "madge": "^8.0.0",
    "next": "16.2.6",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "turbo": "2.10.4",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{js,ts,cjs,mjs,jsx,tsx,json,jsonc}": [
      "bunx @biomejs/biome check --write --no-errors-on-unmatched"
    ]
  },
  "packageManager": "bun@1.4.0-canary.1",
  "engines": {
    "node": ">=24.0.0"
  },
  "overrides": {
    "@elizaos/core": "2.0.0-alpha.109",
    "dotenv": "^16.4.5",
    "@langchain/core": "1.1.36",
    "langsmith": "0.5.15",
    "dompurify": "3.3.3",
    "valibot": "1.3.1",
    "socket.io-parser": "4.2.6",
    "undici": "6.24.1",
    "tmp": "0.2.5",
    "diff": "4.0.4",
    "preact": "10.29.0",
    "rollup": "4.60.0",
    "esbuild": "0.27.4",
    "webpack": "5.105.4",
    "yaml": "2.8.3",
    "nanoid": "5.1.7",
    "tar": "7.5.13",
    "h3": "1.15.10",
    "ajv": "8.18.0",
    "lodash": "4.17.23",
    "lodash-es": "4.17.23",
    "smol-toml": "1.6.1",
    "serialize-javascript": "7.0.5",
    "axios": "1.14.0",
    "@isaacs/brace-expansion": "5.0.1",
    "glob": "10.5.0",
    "minimatch": ">=3.1.5",
    "picomatch": "4.0.4",
    "handlebars": "4.7.9",
    "immutable": "5.1.5",
    "bn.js": "5.2.3",
    "@feed/crypto-browserify": "workspace:*",
    "tsup": "8.5.1",
    "hono": "4.12.9",
    "fast-xml-parser": "5.5.9",
    "parse-duration": "2.1.5",
    "qs": "6.15.0",
    "cookie": "1.1.1",
    "path-to-regexp": "0.1.13",
    "ws": "8.21.0"
  },
  "trustedDependencies": [
    "@reown/appkit",
    "@sentry/cli",
    "@tree-sitter-grammars/tree-sitter-yaml",
    "core-js",
    "core-js-pure",
    "protobufjs"
  ]
}
