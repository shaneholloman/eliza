{
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "es2022",
    "strict": true,
    "skipLibCheck": true,
    "types": ["node", "bun"]
  },
  "include": [
    "playwright.config.ts",
    "global-setup.ts",
    "dev-server.ts",
    "specs/**/*.ts",
    "synpress/**/*.ts",
    "synpress.d.ts"
  ]
}
