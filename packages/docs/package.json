{
  "name": "@elizaos/docs",
  "version": "2.0.0-beta.2",
  "type": "module",
  "description": "elizaOS documentation",
  "scripts": {
    "test": "bun test ./test",
    "predev": "node ../shared/scripts/sync-to-public.mjs ./public --logos --favicons --ogembeds --banners",
    "prebuild": "node ../shared/scripts/sync-to-public.mjs ./public --logos --favicons --ogembeds --banners",
    "lint": "bunx @biomejs/biome check --write --unsafe package.json docs.json test",
    "lint:check": "bunx @biomejs/biome check package.json docs.json test",
    "lint:fix": "bunx @biomejs/biome check --write --unsafe package.json docs.json test",
    "format": "bunx @biomejs/biome format --write package.json docs.json test",
    "format:check": "bunx @biomejs/biome format package.json docs.json test"
  },
  "private": true
}
