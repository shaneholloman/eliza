{
  "provider_mode": "mock",
  "surfaces": [
    "zoom",
    "google_meet",
    "on_device",
    "cloud_agent",
    "hybrid_local_cloud"
  ],
  "capture_modes": [
    "bot",
    "bot_free"
  ],
  "transcript_schema": {
    "required_fields": [
      "meeting_id",
      "source",
      "consent",
      "segments",
      "speakers",
      "artifacts",
      "retention_policy"
    ]
  },
  "adapters": [
    {
      "id": "zoom",
      "capture_modes": ["bot", "bot_free"]
    },
    {
      "id": "google_meet",
      "capture_modes": ["bot", "bot_free"]
    },
    {
      "id": "on_device_capture",
      "capture_modes": ["bot_free"]
    }
  ],
  "stressors": [
    "music",
    "noise",
    "babble",
    "overlap",
    "far_field"
  ],
  "scenarios": [
    {
      "id": "clean_single_speaker",
      "surface": "on_device",
      "capture_mode": "bot_free",
      "evidence": ["transcript_artifact", "metrics"]
    },
    {
      "id": "zoom_bot",
      "surface": "zoom",
      "capture_mode": "bot",
      "evidence": ["audio", "video", "backend_logs", "transcript_artifact"]
    },
    {
      "id": "zoom_bot_free",
      "surface": "zoom",
      "capture_mode": "bot_free",
      "evidence": ["audio", "frontend_logs", "screenshots", "transcript_artifact"]
    },
    {
      "id": "google_meet_bot",
      "surface": "google_meet",
      "capture_mode": "bot",
      "evidence": ["audio", "video", "backend_logs", "transcript_artifact"]
    },
    {
      "id": "google_meet_bot_free",
      "surface": "google_meet",
      "capture_mode": "bot_free",
      "evidence": ["audio", "frontend_logs", "screenshots", "transcript_artifact"]
    },
    {
      "id": "on_device_capture",
      "surface": "on_device",
      "capture_mode": "bot_free",
      "evidence": ["audio", "metrics", "transcript_artifact"]
    },
    {
      "id": "cloud_agent_capture",
      "surface": "cloud_agent",
      "capture_mode": "bot",
      "evidence": ["backend_logs", "model_trajectories", "transcript_artifact"]
    },
    {
      "id": "hybrid_local_cloud",
      "surface": "hybrid_local_cloud",
      "capture_mode": "bot_free",
      "evidence": ["audio", "backend_logs", "frontend_logs", "model_trajectories"]
    },
    {
      "id": "multiple_people_single_stream",
      "surface": "google_meet",
      "capture_mode": "bot_free",
      "evidence": ["audio", "video", "speaker_profile_artifact"]
    },
    {
      "id": "shared_room_microphone",
      "surface": "zoom",
      "capture_mode": "bot_free",
      "evidence": ["audio", "video", "speaker_profile_artifact"]
    },
    {
      "id": "speech_over_music",
      "surface": "on_device",
      "capture_mode": "bot_free",
      "evidence": ["audio", "metrics", "transcript_artifact"]
    },
    {
      "id": "speech_over_noise",
      "surface": "on_device",
      "capture_mode": "bot_free",
      "evidence": ["audio", "metrics", "transcript_artifact"]
    },
    {
      "id": "speech_over_babble",
      "surface": "on_device",
      "capture_mode": "bot_free",
      "evidence": ["audio", "metrics", "transcript_artifact"]
    },
    {
      "id": "overlapped_speech",
      "surface": "cloud_agent",
      "capture_mode": "bot",
      "evidence": ["audio", "metrics", "speaker_profile_artifact"]
    },
    {
      "id": "far_field_room",
      "surface": "zoom",
      "capture_mode": "bot_free",
      "evidence": ["audio", "video", "metrics"]
    },
    {
      "id": "known_speaker_recognition",
      "surface": "hybrid_local_cloud",
