  "speaker_operations": [
    {
      "id": "known_speaker_enrollment",
      "surface": "on_device",
      "evidence": ["audio", "speaker_profile_artifact", "consent_record"],
      "metrics": ["voice_profile_false_reject_rate", "speaker_identity_quality"],
      "privacy_control": "explicit opt-in enrollment with profile artifact review",
      "confidence_policy": "store profile only when enrollment clip and consent record both pass"
    },
    {
      "id": "known_speaker_recognition",
      "surface": "hybrid_local_cloud",
      "evidence": ["audio", "speaker_profile_artifact", "metrics"],
      "metrics": ["voice_profile_false_accept_rate", "voice_profile_false_reject_rate", "speaker_identity_quality"],
      "privacy_control": "speaker labels are user-visible and editable before sharing",
      "confidence_policy": "attach a known name only above threshold, otherwise keep an unknown speaker label"
    },
    {
      "id": "unknown_speaker_creation",
      "surface": "hybrid_local_cloud",
      "evidence": ["audio", "speaker_profile_artifact", "transcript_artifact"],
      "metrics": ["der", "jer", "speaker_identity_quality"],
      "privacy_control": "unknown profiles remain local unless the user opts in to cloud sync",
      "confidence_policy": "create a temporary unknown speaker only after repeated segments exceed clustering confidence"
    },
    {
      "id": "speaker_name_correction",
      "surface": "hybrid_local_cloud",
      "evidence": ["screenshots", "speaker_profile_artifact", "transcript_artifact"],
      "metrics": ["speaker_attributed_wer", "speaker_identity_quality"],
      "privacy_control": "manual label edits are auditable and reversible",
      "confidence_policy": "manual corrections override model labels for that transcript and future opted-in profiles"
    },
    {
      "id": "duplicate_speaker_merge",
      "surface": "cloud_agent",
      "evidence": ["speaker_profile_artifact", "transcript_artifact", "model_trajectories"],
      "metrics": ["der", "speaker_attributed_wer", "speaker_identity_quality"],
      "privacy_control": "merge requires explicit review of affected transcript segments",
      "confidence_policy": "suggest merge only when voice and roster signals agree"
    },
    {
      "id": "incorrect_speaker_split",
      "surface": "cloud_agent",
      "evidence": ["speaker_profile_artifact", "transcript_artifact", "model_trajectories"],
      "metrics": ["der", "jer", "speaker_attributed_wer"],
      "privacy_control": "split preserves both profile histories with user-confirmed names",
      "confidence_policy": "suggest split when segment embeddings and active-speaker video disagree with current label"
    },
    {
      "id": "voice_profile_deletion",
      "surface": "hybrid_local_cloud",
      "evidence": ["speaker_profile_artifact", "retention_artifact", "consent_record"],
      "metrics": ["consent_retention_quality", "speaker_identity_quality"],
      "privacy_control": "delete removes stored voice profile material and records retention proof",
      "confidence_policy": "deleted profiles must not be used for recognition in later runs"
    },
    {
      "id": "post_deletion_non_recognition",
      "surface": "hybrid_local_cloud",
      "evidence": ["audio", "retention_artifact", "metrics"],
      "metrics": ["voice_profile_false_accept_rate", "consent_retention_quality"],
      "privacy_control": "post-deletion replay proves no stale profile can identify the speaker",
      "confidence_policy": "speaker remains unknown unless newly enrolled with fresh consent"
    },
    {
      "id": "multi_speaker_single_stream_attribution",
      "surface": "google_meet",
      "evidence": ["audio", "video", "speaker_profile_artifact", "metrics"],
      "metrics": ["der", "jer", "active_speaker_accuracy", "speaker_attributed_wer"],
      "privacy_control": "single camera/microphone rooms require visible uncertainty when labels are inferred",
      "confidence_policy": "combine diarization, active-speaker video, and roster priors before naming speakers"
    },
    {
      "id": "shared_room_uncertainty",
      "surface": "zoom",
      "evidence": ["audio", "video", "speaker_profile_artifact", "transcript_artifact"],
      "metrics": ["der", "active_speaker_accuracy", "speaker_identity_quality"],
      "privacy_control": "shared-room transcripts expose confidence and avoid overconfident names",
      "confidence_policy": "prefer room-level labels when visual or voice evidence is ambiguous"
    }
  ],
  "speaker_name_provenance": [
    {
      "id": "platform_roster_name",
      "source": "platform_roster",
      "surface": "zoom",
      "evidence": ["transcript_artifact", "speaker_profile_artifact"],
      "signals": ["platform_label"],
      "confidence": 0.91,
      "conflict_policy": "apply only when roster, diarization, and profile context do not conflict",
      "confidence_policy": "confirmed labels require high confidence and provenance in the transcript JSON",
      "privacy_policy": "show source and confidence next to the displayed name",
      "expected_resolution": "apply_name"
    },
    {
      "id": "calendar_attendee_name",
      "source": "calendar_attendee",
      "surface": "google_meet",
      "evidence": ["transcript_artifact", "screenshots"],
      "signals": ["calendar_attendee"],
      "confidence": 0.72,
      "conflict_policy": "calendar-only matches stay tentative when roster or voice evidence is absent",
      "confidence_policy": "medium confidence attendee matches ask the user before confirmed display",
      "privacy_policy": "calendar attendee names remain scoped to the meeting artifact",
      "expected_resolution": "request_confirmation"
    },
    {
      "id": "self_introduction_name",
      "source": "self_introduction",
      "surface": "hybrid_local_cloud",
