{
  "name": "@elizaos-benchmarks/lib",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Shared TS schemas + helpers for the LifeOpsBench benchmark + prompt-optimization pipeline.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./metrics-schema": "./src/metrics-schema.ts",
    "./model-tiers": "./src/model-tiers.ts",
    "./local-llama-cpp": "./src/local-llama-cpp.ts"
  },
  "scripts": {
    "test": "vitest run",
    "lint": "bunx @biomejs/biome check --write --unsafe .",
    "lint:check": "bunx @biomejs/biome check .",
    "format": "bunx @biomejs/biome format --write .",
    "format:check": "bunx @biomejs/biome format .",
    "typecheck": "tsgo --noEmit",
    "check": "bun run typecheck && bun run lint:check && bun run format:check"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "typescript": "^6.0.3",
    "vitest": "4.1.9"
  }
}
