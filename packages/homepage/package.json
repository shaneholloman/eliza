{
  "name": "eliza-app",
  "version": "2.0.0-beta.2",
  "type": "module",
  "scripts": {
    "predev": "node ../shared/scripts/sync-to-public.mjs ./public --logos --favicons --ogembeds --background --background-videos && node ../app-core/scripts/write-homepage-release-data.mjs",
    "dev": "bun --bun vite",
    "prebuild": "node ../shared/scripts/sync-to-public.mjs ./public --logos --favicons --ogembeds --background --background-videos && node ../app-core/scripts/write-homepage-release-data.mjs",
    "build": "bun --bun vite build",
    "clean": "node ../scripts/rm-path-recursive.mjs dist",
    "check:release-data": "node ../app-core/scripts/check-homepage-release-data.mjs",
    "test": "bun test tests/smoke.node.test.mjs tests/contact.test.ts",
    "test:e2e": "node ../app-core/scripts/write-homepage-release-data.mjs && playwright test",
    "test:audit": "node ../app-core/scripts/write-homepage-release-data.mjs && playwright test tests/e2e/aesthetic-audit.spec.ts && playwright test tests/e2e/contact-sheet-capture.spec.ts && node scripts/generate-contact-sheet.mjs",
    "typecheck": "node ../app-core/scripts/write-homepage-release-data.mjs && tsc -b",
    "preview": "bun --bun vite preview --port 4444",
    "lint": "bunx @biomejs/biome check --write --unsafe .",
    "lint:check": "bunx @biomejs/biome check .",
    "format": "bunx @biomejs/biome format --write .",
    "format:check": "bunx @biomejs/biome format ."
  },
  "dependencies": {
    "@elizaos/ui": "workspace:*",
    "@fontsource/poppins": "^5.2.7",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-slot": "^1.2.4",
    "@react-spring/three": "^10.0.3",
    "@react-spring/web": "^10.0.3",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@tanstack/react-query": "^5.90.20",
    "@use-gesture/react": "^10.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "country-flag-icons": "^1.6.12",
    "libphonenumber-js": "^1.12.35",
    "lucide-react": "^1.0.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-router-dom": "^7.10.0",
    "tailwind-merge": "^3.4.0",
    "three": "^0.184.0",
    "@elizaos/shared": "workspace:*"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^24.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-react": "^6.0.0",
    "playwright": "^1.59.1",
    "sharp": "^0.34.5",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.0"
  },
  "private": true
}
