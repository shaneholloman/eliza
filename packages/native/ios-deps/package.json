{
  "name": "@elizaos/ios-native-deps",
  "version": "0.1.0",
  "private": true,
  "description": "iOS cross-build harness for native dependencies used by on-device runtimes: llama.cpp (LlamaCpp.xcframework via elizaOS/llama.cpp fork) and sqlite-vec.",
  "keywords": [
    "ios",
    "xcframework",
    "llama.cpp",
    "sqlite-vec",
    "metal",
    "cross-compile",
    "eliza"
  ],
  "author": "elizaOS",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elizaOS/eliza.git",
    "directory": "packages/native/ios-deps"
  },
  "os": [
    "darwin"
  ],
  "scripts": {
    "build:llama-cpp": "node ../../../packages/scripts/run-bash-darwin-only.mjs packages/native/ios-deps/llama.cpp/build-ios.sh",
    "build:llama-cpp:device": "node ../../../packages/scripts/run-bash-darwin-only.mjs packages/native/ios-deps/llama.cpp/build-ios.sh device",
    "build:llama-cpp:simulator": "node ../../../packages/scripts/run-bash-darwin-only.mjs packages/native/ios-deps/llama.cpp/build-ios.sh simulator",
    "clean:llama-cpp": "node ../../../packages/scripts/run-bash-darwin-only.mjs packages/native/ios-deps/llama.cpp/build-ios.sh clean",
    "build:sqlite-vec": "node ../../../packages/scripts/run-bash-darwin-only.mjs packages/native/ios-deps/sqlite-vec/build-ios.sh",
    "build:sqlite-vec:device": "node ../../../packages/scripts/run-bash-darwin-only.mjs packages/native/ios-deps/sqlite-vec/build-ios.sh device",
    "build:sqlite-vec:simulator": "node ../../../packages/scripts/run-bash-darwin-only.mjs packages/native/ios-deps/sqlite-vec/build-ios.sh simulator",
    "clean:sqlite-vec": "node ../../../packages/scripts/run-bash-darwin-only.mjs packages/native/ios-deps/sqlite-vec/build-ios.sh clean",
    "build:stamp": "node -e \"const fs=require('node:fs'); fs.mkdirSync('.turbo/native-deps-build', { recursive: true }); fs.writeFileSync('.turbo/native-deps-build/stamp', 'ok\\n');\"",
    "build": "bun run build:llama-cpp && bun run build:sqlite-vec && bun run build:stamp",
    "lint": "bunx @biomejs/biome check --write --unsafe .",
    "lint:check": "bunx @biomejs/biome check .",
    "lint:fix": "bunx @biomejs/biome check --write --unsafe .",
    "format": "bunx @biomejs/biome format --write .",
    "format:check": "bunx @biomejs/biome format .",
    "clean": "bun run clean:llama-cpp && bun run clean:sqlite-vec && node ../../../packages/scripts/rm-path-recursive.mjs .turbo/native-deps-build"
  },
  "files": [
    "VERSIONS",
    "llama.cpp/build-ios.sh",
    "llama.cpp/shim/",
    "llama.cpp/README.md",
    "sqlite-vec/build-ios.sh",
    "sqlite-vec/README.md",
    "README.md"
  ]
}
