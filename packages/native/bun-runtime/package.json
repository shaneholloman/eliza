{
  "name": "@elizaos/bun-ios-runtime",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Build and validation harness for the full Bun engine on iOS",
  "license": "MIT",
  "scripts": {
    "check": "node scripts/check-upstream-support.mjs",
    "check:strict": "node scripts/check-upstream-support.mjs --strict",
    "build:sim": "node scripts/build-ios-bun-engine.mjs --target=simulator",
    "build:device": "node scripts/build-ios-bun-engine.mjs --target=device",
    "verify:app-store": "node scripts/verify-ios-app-store.mjs",
    "test": "node --test scripts/*.test.mjs",
    "smoke:sim": "node scripts/smoke-ios-bun-engine.mjs --target=simulator",
    "smoke:device": "node scripts/smoke-ios-bun-engine.mjs --target=device",
    "lint": "bunx @biomejs/biome check --write --unsafe .",
    "lint:check": "bunx @biomejs/biome check .",
    "lint:fix": "bunx @biomejs/biome check --write --unsafe .",
    "format": "bunx @biomejs/biome format --write .",
    "format:check": "bunx @biomejs/biome format ."
  },
  "files": [
    "ElizaBunEngine.podspec",
    "README.md",
    "BRIDGE_CONTRACT.md",
    "Sources/",
    "scripts/"
  ]
}
