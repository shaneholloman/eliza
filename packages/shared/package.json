        "import": "./src/voice-eot.ts",
        "default": "./src/voice-eot.ts"
      },
      "import": "./dist/voice-eot.js",
      "default": "./dist/voice-eot.js"
    },
    "./voice/respond-gate": {
      "types": "./dist/voice/respond-gate.d.ts",
      "eliza-source": {
