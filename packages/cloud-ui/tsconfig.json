{
  "compilerOptions": {
    "target": "ES2024",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "types": ["node", "react"],
    "allowImportingTsExtensions": true,
    "declaration": false,
    "noEmit": true,
    "paths": {
      "@elizaos/ui": ["../ui/src/index.ts"],
      "@elizaos/ui/*": ["../ui/src/*"],
      "@elizaos/shared": ["../shared/src/index.ts"],
      "@elizaos/shared/*": ["../shared/src/*"],
      "@elizaos/core": ["../core/src/index.ts"],
      "@elizaos/core/*": ["../core/src/*"],
      "@elizaos/cloud-shared": ["../cloud/shared/src/index.ts"],
      "@elizaos/cloud-shared/*": ["../cloud/shared/src/*"],
      "@elizaos/*": ["../../node_modules/@elizaos/*"]
    }
  },
  "include": ["src"]
}
