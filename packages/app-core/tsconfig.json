      "@elizaos/vault": ["../vault/src/index.ts"],
      "@elizaos/skills": ["../skills/src/index.ts"],
      "@elizaos/capacitor-gateway": [
        "../../plugins/plugin-native-gateway/src/index.ts"
      ],
      "@elizaos/capacitor-camera": [
