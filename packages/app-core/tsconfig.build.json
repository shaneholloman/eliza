{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "declaration": true,
    "declarationMap": true,
    "noEmit": false,
    "outDir": "./dist",
    "resolveJsonModule": true,
    "rootDir": "../../",
    "rewriteRelativeImportExtensions": true,
    "stripInternal": true,
    "tsBuildInfoFile": "./dist/.tsbuildinfo",
    "paths": {
      "@elizaos/app-core": ["./src/index.ts"],
      "@elizaos/agent": ["../agent/dist/packages/agent/src/index.d.ts"],
      "@elizaos/agent/*": ["../agent/dist/packages/agent/src/*"],
      "@elizaos/core": ["../core/dist/index.node.d.ts"],
      "@elizaos/shared": ["../shared/dist/index.d.ts"],
      "@elizaos/ui": ["../ui/dist/index.d.ts"],
      "@elizaos/vault": ["../vault/dist/index.d.ts"],
      "@elizaos/plugin-browser": [
        "../../plugins/plugin-browser/dist/index.d.ts"
      ],
      "@elizaos/plugin-elizacloud": [
        "../../plugins/plugin-elizacloud/dist/index.node.d.ts"
      ],
      "@elizaos/plugin-remote-manifest": [
        "../plugin-remote-manifest/dist/index.d.ts"
      ],
      "@elizaos/plugin-remote-manifest/*": ["../plugin-remote-manifest/dist/*"],
      "@elizaos/plugin-sql": ["../../plugins/plugin-sql/src/index.node.ts"],
      "@elizaos/plugin-wechat": ["../../plugins/plugin-wechat/dist/index.d.ts"],
      "@elizaos/capacitor-canvas": [
        "../../plugins/plugin-native-canvas/dist/esm/index.d.ts"
      ],
      "@elizaos/capacitor-location": [
        "../../plugins/plugin-native-location/dist/esm/index.d.ts"
      ],
      "@elizaos/capacitor-mobile-signals": [
        "../../plugins/plugin-native-mobile-signals/dist/esm/index.d.ts"
      ],
      "@elizaos/capacitor-appblocker": [
        "../../plugins/plugin-native-appblocker/dist/esm/index.d.ts"
      ],
      "@elizaos/capacitor-phone": [
        "../../plugins/plugin-native-phone/dist/esm/index.d.ts"
      ],
      "@elizaos/capacitor-screencapture": [
        "../../plugins/plugin-native-screencapture/dist/esm/index.d.ts"
      ],
      "drizzle-orm": ["../../plugins/plugin-sql/node_modules/drizzle-orm"],
      "drizzle-orm/*": ["../../plugins/plugin-sql/node_modules/drizzle-orm/*"],
      "react": ["./node_modules/@types/react/index.d.ts"],
      "react/jsx-runtime": ["./node_modules/@types/react/jsx-runtime.d.ts"],
      "react/jsx-dev-runtime": [
        "./node_modules/@types/react/jsx-dev-runtime.d.ts"
      ],
      "react-dom": ["./node_modules/@types/react-dom/index.d.ts"]
    }
  },
  "exclude": [
    "src/**/*.stories.ts",
    "src/**/*.stories.tsx",
    "src/**/*.test.ts",
    "src/**/*.test.tsx"
  ],
  "include": ["src", "../agent/src/external-modules.d.ts"]
}
