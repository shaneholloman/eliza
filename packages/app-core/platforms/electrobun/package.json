{
  "name": "@elizaos/electrobun",
  "version": "2.0.3-beta.7",
  "type": "module",
  "files": [
    "assets",
    "entitlements",
    "scripts",
    "remotes",
    "src",
    "electrobun.config.ts",
    "README.md",
    "tsconfig.json"
  ],
  "scripts": {
    "dev": "bun run build:preload && PATH=\"$PWD/scripts/bin:$PATH\" bunx electrobun dev",
    "build": "cd ../../../.. && node packages/app-core/scripts/desktop-build.mjs build",
    "typecheck": "tsgo --noEmit",
    "test": "bunx vitest run --config vitest.electrobun.config.ts --passWithNoTests",
    "lint": "bunx @biomejs/biome check $(find src -type f \\( -name '*.ts' -o -name '*.tsx' \\) ! -name '*.d.ts' -print)",
    "voice:validate": "bun src/voice/voice-live-validation.ts",
    "voice:validate:dry": "bun src/voice/voice-live-validation.ts",
    "voice:validate:live": "bun src/voice/voice-live-validation.ts",
    "build:preload": "node ../../scripts/build-electrobun-preload.mjs",
    "build:native-effects": "bash scripts/build-macos-effects.sh"
  },
  "dependencies": {
    "@elizaos/agent": "workspace:*",
    "@elizaos/app-core": "workspace:*",
    "@elizaos/plugin-remote-manifest": "workspace:*",
    "@elizaos/plugin-browser": "workspace:*",
    "@elizaos/plugin-capacitor-bridge": "workspace:*",
    "@elizaos/plugin-local-inference": "workspace:*",
    "@elizaos/plugin-registry": "workspace:*",
    "@elizaos/plugin-streaming": "workspace:*",
    "@elizaos/shared": "workspace:*",
    "bonjour-service": "1.4.2",
    "electrobun": "^1.18.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@types/bun": "^1.3.8",
    "rcedit": "5.0.2",
    "typescript": "^6.0.3",
    "vitest": "^4.0.18"
  },
  "publishConfig": {
    "access": "public"
  },
  "elizaos": {
    "scripts": {
      "turboNonImportedBuildDeps": true
    }
  }
}
