{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"esModuleInterop": true,
		"strict": true,
		"skipLibCheck": true,
		"ignoreDeprecations": "6.0",
		"jsx": "react-jsx",
		"declaration": true,
		"declarationMap": true,
		"outDir": "./dist",
		"rootDir": "../..",
		"lib": ["ES2022", "DOM"],
		"types": ["node"],
		"typeRoots": [
			"./node_modules/@types",
			"../../node_modules/@types",
			"../../node_modules/.bun/node_modules/@types"
		],
		"allowImportingTsExtensions": true,
		"rewriteRelativeImportExtensions": true,
		"paths": {
			"@elizaos/core": ["../../packages/core/src/index.node.ts"],
			"@elizaos/logger": ["../../packages/logger/src/index.ts"],
			"@elizaos/shared": ["../../packages/shared/src/index.ts"],
			"@elizaos/shared/*": ["../../packages/shared/src/*"],
			"@elizaos/ui": ["../../packages/ui/src/index.ts"],
			"@elizaos/ui/*": ["../../packages/ui/src/*"],
			"@elizaos/import-conversations": [
				"../../packages/import-conversations/src/index.ts"
			],
			"@elizaos/import-conversations/*": [
				"../../packages/import-conversations/src/*"
			],
			"@elizaos/import-conversations/browser": [
				"../../packages/import-conversations/src/browser.ts"
			]
		}
	},
	"include": ["src/**/*"],
	"exclude": [
		"node_modules",
		"dist",
		"src/**/__tests__/**",
		"src/**/*.test.ts",
		"src/**/*.test.tsx",
		"**/__tests__/**",
		"**/*.test.ts",
		"**/*.test.tsx",
		"**/*.e2e.test.ts",
		"src/views/**"
	]
}
