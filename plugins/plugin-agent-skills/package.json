{
  "name": "@elizaos/plugin-agent-skills",
  "version": "2.0.3-beta.7",
  "description": "Agent Skills plugin for elizaOS - implement the Agent Skills specification with progressive disclosure",
  "main": "dist/index.js",
  "type": "module",
  "types": "dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "eliza-source": {
        "types": "./src/index.ts",
        "import": "./src/index.ts",
        "default": "./src/index.ts"
      },
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./*.css": "./dist/*.css",
    "./*": {
      "types": "./dist/*.d.ts",
      "eliza-source": {
        "types": "./src/*.ts",
        "import": "./src/*.ts",
        "default": "./src/*.ts"
      },
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    }
  },
  "files": [
    "registry-entry.json",
    "dist",
    "auto-enable.ts"
  ],
  "elizaos": {
    "plugin": {
      "autoEnableModule": "./auto-enable.ts",
      "capabilities": [
        "agent-skills"
      ]
    }
  },
  "keywords": [
    "elizaos",
    "plugin",
    "agent-skills",
    "clawhub",
    "otto",
    "skills",
    "agents",
    "progressive-disclosure"
  ],
  "dependencies": {
    "@elizaos/core": "workspace:*",
    "@elizaos/shared": "workspace:*",
    "@elizaos/skills": "workspace:*",
    "fflate": "^0.8.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.0.0"
  },
  "scripts": {
    "build": "tsup && tsc --declaration --emitDeclarationOnly --noEmit false --noCheck",
    "dev": "tsup --watch",
    "clean": "node ../../packages/scripts/rm-path-recursive.mjs dist",
    "lint": "bunx @biomejs/biome check --write --unsafe --config-path ./biome.json .",
    "lint:check": "bunx @biomejs/biome lint --config-path ./biome.json . --no-errors-on-unmatched",
    "format": "bunx @biomejs/biome format --write . --no-errors-on-unmatched",
    "format:check": "bunx @biomejs/biome format . --no-errors-on-unmatched",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run --config ./vitest.config.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "agentConfig": {
    "pluginType": "elizaos:plugin:1.0.0",
    "pluginParameters": {
      "SKILLS_DIR": {
        "type": "string",
        "description": "Directory to install and load skills from (default: ./skills)",
        "required": false,
        "example": "./skills"
      },
      "SKILLS_AUTO_LOAD": {
        "type": "boolean",
        "description": "Automatically load installed skills on startup",
        "required": false,
        "example": "true"
      },
      "SKILLS_REGISTRY": {
        "type": "string",
        "description": "Skill registry URL (default: https://clawhub.ai)",
        "required": false,
        "example": "https://clawhub.ai"
      },
      "BUNDLED_SKILLS_DIRS": {
        "type": "string",
        "description": "Comma-separated list of directories containing bundled (read-only) skills",
        "required": false,
        "example": "./bundled-skills,./vendor-skills"
      },
      "OTTO_BUNDLED_SKILLS_DIR": {
        "type": "string",
        "description": "Legacy: Single directory containing Otto bundled skills",
        "required": false,
        "example": "./otto/skills"
      }
    }
  },
  "eliza": {
    "platforms": [
      "node"
    ],
    "runtime": "node",
    "platformDetails": {
      "node": "Node.js via main entry point"
    }
  }
}
