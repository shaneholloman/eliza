{
  "name": "@elizaos/plugin-form",
  "version": "2.0.3-beta.7",
  "type": "module",
  "description": "Eliza plugin-form: conversational forms as guardrails for guided user journeys.",
  "main": "./dist/index.js",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "eliza-source": {
        "types": "./src/index.ts",
        "import": "./src/index.ts",
        "default": "./src/index.ts"
      },
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./*.css": "./dist/*.css",
    "./*": {
      "types": "./dist/*.d.ts",
      "eliza-source": {
        "types": "./src/*.ts",
        "import": "./src/*.ts",
        "default": "./src/*.ts"
      },
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    }
  },
  "dependencies": {
    "@elizaos/core": "workspace:*",
    "uuid": "^14.0.0"
  },
  "agentConfig": {
    "pluginType": "elizaos:plugin:1.0.0",
    "pluginParameters": {},
    "description": "Conversational forms for structured data collection."
  },
  "elizaos": {
    "app": {
      "heroImage": "assets/hero.png"
    },
    "plugin": {
      "autoEnableModule": "./auto-enable.ts",
      "capabilities": [
        "forms"
      ]
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "bun run build:js && bun run build:types",
    "clean": "node ../../packages/scripts/rm-path-recursive.mjs dist",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsgo --noEmit -p tsconfig.json",
    "build:js": "tsup --config ../tsup.plugin-packages.shared.ts",
    "build:types": "tsc --noCheck -p tsconfig.build.json",
    "lint": "bunx @biomejs/biome check --write --unsafe .",
    "lint:check": "bunx @biomejs/biome check .",
    "format": "bunx @biomejs/biome format --write .",
    "format:check": "bunx @biomejs/biome format ."
  },
  "files": [
    "registry-entry.json",
    "dist",
    "auto-enable.ts"
  ],
  "devDependencies": {
    "@types/node": "^25.0.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.0.18"
  }
}
