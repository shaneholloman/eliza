{
  "name": "@elizaos/capacitor-location",
  "version": "2.0.3-beta.7",
  "description": "Reads current location, watches movement, and manages geolocation permissions.",
  "keywords": [
    "location",
    "geolocation",
    "device",
    "permissions"
  ],
  "main": "./dist/plugin.cjs.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "bun": "./src/index.ts",
      "development": "./src/index.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/plugin.cjs.js"
    },
    "./package.json": "./package.json"
  },
  "unpkg": "dist/plugin.js",
  "files": [
    "android/src/main/",
    "android/build.gradle",
    "dist/",
    "ios/Sources/",
    "*.podspec",
    "dist"
  ],
  "scripts": {
    "build": "node ../../packages/scripts/with-package-build-lock.mjs plugins/plugin-native-location -- bun run build:unlocked",
    "build:docs": "bun run clean && bun run docgen && tsc && bun --bun rollup -c rollup.config.mjs",
    "clean": "node ../../packages/scripts/rm-path-recursive.mjs dist",
    "prepublishOnly": "bun run build",
    "test": "vitest run",
    "docgen": "docgen --api LocationPlugin --output-readme README.md --output-json dist/docs.json",
    "build:unlocked": "bun run clean && tsc && bunx rollup -c rollup.config.mjs",
    "typecheck": "tsgo --noEmit -p tsconfig.json",
    "lint": "bunx @biomejs/biome check --write --unsafe .",
    "lint:check": "bunx @biomejs/biome check .",
    "format": "bunx @biomejs/biome format --write .",
    "format:check": "bunx @biomejs/biome format ."
  },
  "author": "elizaOS",
  "license": "MIT",
  "dependencies": {},
  "repository": {
    "type": "git",
    "url": "https://github.com/elizaOS/eliza.git",
    "directory": "apps/app/plugins/location"
  },
  "capacitor": {
    "ios": {
      "src": "ios",
      "podName": "ElizaCapacitorLocation"
    },
    "android": {
      "src": "android"
    }
  },
  "devDependencies": {
    "@capacitor/core": "^8.3.1",
    "@capacitor/docgen": "^0.3.0",
    "rollup": "^4.60.2",
    "typescript": "^6.0.3",
    "vitest": "^4.0.0"
  },
  "peerDependencies": {
    "@capacitor/core": "^8.3.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "elizaos": {
    "platforms": [
      "browser",
      "node"
    ],
    "runtime": "both",
    "platformDetails": {
      "browser": "Full support via Geolocation API (current position, watch position, permissions)",
      "node": "Full support via Electrobun with native geolocation services",
      "ios": true,
      "android": true
    }
  }
}
