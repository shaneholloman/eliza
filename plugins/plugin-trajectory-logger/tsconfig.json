{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "composite": false,
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "types": ["node", "bun"],
    "typeRoots": [
      "./node_modules/@types",
      "../../node_modules/@types",
      "../../../node_modules/@types",
      "../../../node_modules/.bun/node_modules/@types",
      "../../../node_modules",
      "../../../node_modules/.bun/node_modules"
    ],
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "paths": {
      "drizzle-orm": ["../plugin-sql/node_modules/drizzle-orm"],
      "drizzle-orm/*": ["../plugin-sql/node_modules/drizzle-orm/*"],
      "@elizaos/app-core": ["../../packages/app-core/src/index.ts"],
      "@elizaos/app-core/*": ["../../packages/app-core/src/*"],
      "@elizaos/agent": ["../../packages/agent/src/index.ts"],
      "@elizaos/agent/*": ["../../packages/agent/src/*"],
      "@elizaos/plugin-task-coordinator": [
        "../plugin-task-coordinator/src/api/coordinator-types.ts"
      ],
      "@elizaos/plugin-workflow": ["../plugin-workflow/dist/index.d.ts"],
      "@elizaos/plugin-workflow/*": ["../plugin-workflow/dist/*"],
      "@elizaos/core": ["../../packages/core/src/index.ts"],
      "@elizaos/core/*": ["../../packages/core/src/*"],
      "@elizaos/logger": ["../../packages/logger/src/index.ts"],
      "@elizaos/logger/*": ["../../packages/logger/src/*"],
      "@elizaos/plugin-wallet-ui": [
        "../../plugins/plugin-wallet-ui/src/index.ts"
      ],
      "@elizaos/plugin-wallet-ui/*": ["../../plugins/plugin-wallet-ui/src/*"],
      "@elizaos/plugin-local-inference": [
        "../../plugins/plugin-local-inference/src/index.ts"
      ],
      "@elizaos/plugin-local-inference/*": [
        "../../plugins/plugin-local-inference/src/*"
      ],
      "@elizaos/plugin-registry": [
        "../../plugins/plugin-registry/dist/index.d.ts"
      ],
      "@elizaos/plugin-registry/*": ["../../plugins/plugin-registry/dist/*"],
      "@elizaos/ui": ["../../packages/ui/src/index.ts"],
      "@elizaos/ui/*": ["../../packages/ui/src/*"],
      "@elizaos/capacitor-bun-runtime": [
        "../../plugins/plugin-native-bun-runtime/src/index.ts"
      ],
      "@elizaos/capacitor-camera": [
        "../../plugins/plugin-native-camera/src/index.ts"
      ],
      "@elizaos/tui": ["../../packages/tui/src/index.ts"],
      "@elizaos/tui/*": ["../../packages/tui/src/*"],
      "@elizaos/shared": ["../../packages/shared/src/index.ts"],
      "@elizaos/shared/*": ["../../packages/shared/src/*"],
      "@elizaos/vault": ["../../packages/vault/src/index.ts"],
      "@elizaos/vault/*": ["../../packages/vault/src/*"],
      "react": ["../../packages/app-core/node_modules/@types/react/index.d.ts"],
      "react/jsx-runtime": [
        "../../packages/app-core/node_modules/@types/react/jsx-runtime.d.ts"
      ],
      "react/jsx-dev-runtime": [
        "../../packages/app-core/node_modules/@types/react/jsx-dev-runtime.d.ts"
      ],
      "react-dom": [
        "../../packages/app-core/node_modules/@types/react-dom/index.d.ts"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.d.ts",
    "../../packages/agent/src/external-modules.d.ts",
    "../../packages/app-core/src/ambient-modules.d.ts"
  ],
  "exclude": ["src/**/*.stories.ts", "src/**/*.stories.tsx"]
}
