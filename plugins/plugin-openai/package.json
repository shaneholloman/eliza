{
  "name": "@elizaos/plugin-openai",
  "version": "2.0.3-beta.7",
  "type": "module",
  "main": "dist/node/index.node.js",
  "module": "dist/node/index.node.js",
  "types": "dist/index.d.ts",
  "browser": "dist/browser/index.browser.js",
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elizaos-plugins/plugin-openai.git"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "browser": {
        "types": "./dist/browser/index.d.ts",
        "import": "./dist/browser/index.browser.js",
        "default": "./dist/browser/index.browser.js"
      },
      "node": {
        "types": "./dist/node/index.d.ts",
        "import": "./dist/node/index.node.js",
        "default": "./dist/node/index.node.js"
      },
      "default": "./dist/node/index.node.js"
    },
    "./*.css": "./dist/*.css",
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    }
  },
  "files": [
    "registry-entry.json",
    "dist",
    "rust",
    "auto-enable.ts"
  ],
  "elizaos": {
    "plugin": {
      "autoEnableModule": "./auto-enable.ts",
      "capabilities": [
        "text-large",
        "text-small",
        "tool-use",
        "embedding",
        "text-to-speech",
        "image-description"
      ]
    },
    "scripts": {
      "coreBuild": true
    }
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.9",
    "ai": "^6.0.30",
    "js-tiktoken": "^1.0.21"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@elizaos/core": "workspace:*",
    "@elizaos/test-harness": "workspace:*",
    "@types/bun": "^1.3.8",
    "@types/json-schema": "^7.0.15",
    "@types/node": "^25.0.3",
    "typescript": "^6.0.3",
    "uuid": "^14.0.0",
    "vitest": "^4.0.0"
  },
  "peerDependencies": {
    "@elizaos/core": "workspace:*",
    "zod": "^4.4.3"
  },
  "scripts": {
    "build:ts": "bun run build.ts",
    "dev": "bun --hot build.ts",
    "lint": "bunx @biomejs/biome check --write --unsafe .",
    "lint:check": "bunx @biomejs/biome check .",
    "clean": "node ../../packages/scripts/rm-path-recursive.mjs dist .turbo",
    "format": "bunx @biomejs/biome format --write .",
    "format:check": "bunx @biomejs/biome format .",
    "typecheck": "tsgo --noEmit -p tsconfig.json",
    "test": "vitest run --config ./vitest.config.ts",
    "test:ts": "vitest run --config ./vitest.config.ts",
    "test:harness": "bunx vitest run --config vitest.harness.config.ts",
    "build": "bun run build.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "agentConfig": {
    "pluginType": "elizaos:plugin:1.0.0",
    "pluginParameters": {
      "OPENAI_API_KEY": {
        "type": "string",
        "description": "API key used to authenticate requests to the OpenAI API.",
        "required": true,
        "sensitive": true
      },
      "OPENAI_BASE_URL": {
        "type": "string",
        "description": "Base URL for all OpenAI API requests.",
        "required": false,
        "default": "https://api.openai.com/v1",
        "sensitive": false
      },
      "EVOLINK_API_KEY": {
        "type": "string",
        "description": "API key used to authenticate requests to EvoLink's OpenAI-compatible API.",
        "required": false,
        "sensitive": true
      },
      "EVOLINK_BASE_URL": {
        "type": "string",
        "description": "Base URL for EvoLink's OpenAI-compatible API.",
        "required": false,
        "default": "https://direct.evolink.ai/v1",
        "sensitive": false
      },
      "EVOLINK_MODEL": {
        "type": "string",
        "description": "Identifier of the EvoLink chat model to use when EVOLINK_API_KEY enables this plugin.",
        "required": false,
        "default": "gpt-5.2",
        "sensitive": false
      },
      "OPENAI_SMALL_MODEL": {
        "type": "string",
        "description": "Identifier of the small language model to be used (overrides SMALL_MODEL).",
        "required": false,
        "sensitive": false
      },
      "SMALL_MODEL": {
        "type": "string",
        "description": "Fallback identifier for the small language model if OPENAI_SMALL_MODEL is not set.",
        "required": false,
        "default": "gpt-5.4-mini",
        "sensitive": false
      },
      "OPENAI_LARGE_MODEL": {
        "type": "string",
        "description": "Identifier of the large language model to be used (overrides LARGE_MODEL).",
        "required": false,
        "sensitive": false
      },
      "LARGE_MODEL": {
        "type": "string",
        "description": "Fallback identifier for the large language model if OPENAI_LARGE_MODEL is not set.",
        "required": false,
        "default": "gpt-5",
        "sensitive": false
      },
      "OPENAI_EMBEDDING_MODEL": {
        "type": "string",
        "description": "Identifier of the model to use for generating text embeddings.",
        "required": false,
        "default": "text-embedding-3-small",
        "sensitive": false
      },
      "OPENAI_EMBEDDING_URL": {
        "type": "string",
        "description": "Custom base URL for the OpenAI embeddings endpoint.",
        "required": false,
        "sensitive": false
      },
      "OPENAI_EMBEDDING_API_KEY": {
        "type": "string",
        "description": "Custom API key for the OpenAI embeddings endpoint.",
        "required": false,
        "sensitive": true
      },
      "OPENAI_EMBEDDING_DIMENSIONS": {
        "type": "number",
        "description": "Number of dimensions for the returned embedding vectors.",
        "required": false,
        "default": 1536,
        "sensitive": false
      },
      "OPENAI_IMAGE_DESCRIPTION_API_KEY": {
        "type": "string",
        "description": "Optional API key for image-description requests. Falls back to the general OpenAI API key when unset.",
        "required": false,
        "sensitive": true
      },
      "OPENAI_IMAGE_DESCRIPTION_BASE_URL": {
        "type": "string",
        "description": "Optional OpenAI-compatible base URL for image-description requests. Useful when text models use a non-vision-compatible endpoint.",
        "required": false,
        "sensitive": false
      },
      "OPENAI_IMAGE_DESCRIPTION_MODEL": {
        "type": "string",
        "description": "Identifier of the model used for describing images.",
        "required": false,
        "default": "gpt-5-mini",
        "sensitive": false
      },
      "OPENAI_IMAGE_DESCRIPTION_MAX_TOKENS": {
        "type": "number",
        "description": "Maximum number of tokens allowed in the image-description model response.",
        "required": false,
        "default": 8192,
        "sensitive": false
      },
      "OPENAI_TTS_MODEL": {
        "type": "string",
        "description": "Identifier of the model used for text-to-speech generation.",
        "required": false,
        "default": "gpt-5-mini-tts",
        "sensitive": false
      },
      "OPENAI_TTS_VOICE": {
        "type": "string",
        "description": "Voice profile to use for text-to-speech output.",
        "required": false,
        "default": "nova",
        "sensitive": false
      },
      "OPENAI_TTS_INSTRUCTIONS": {
        "type": "string",
        "description": "Optional instructions to control the style or behavior of the text-to-speech request.",
        "required": false,
        "sensitive": false
      },
      "OPENAI_EXPERIMENTAL_TELEMETRY": {
        "type": "boolean",
        "description": "Enable experimental telemetry features for enhanced debugging and usage analytics.",
        "required": false,
        "default": false,
        "sensitive": false
      },
      "OPENAI_BROWSER_BASE_URL": {
        "type": "string",
        "description": "Browser-only proxy endpoint base URL for OpenAI requests (no secrets in the client).",
        "required": false,
        "sensitive": false
      },
      "OPENAI_BROWSER_EMBEDDING_URL": {
        "type": "string",
        "description": "Browser-only proxy endpoint base URL for OpenAI embeddings.",
        "required": false,
        "sensitive": false
      }
    }
  },
  "gitHead": "646c632924826e2b75c2304a75ee56959fe4a460",
  "eliza": {
    "platforms": [
      "browser",
      "node"
    ],
    "runtime": "both",
    "platformDetails": {
      "browser": "Browser-compatible build available via exports.browser",
      "node": "Node.js build available via exports.node"
    }
  }
}
