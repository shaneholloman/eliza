{
	"$schema": "https://biomejs.dev/schemas/2.5.1/schema.json",
	"root": false,
	"files": {
		"includes": ["**", "!dist", "!native", "!node_modules"]
	},
	"overrides": [
		{
			"includes": ["**/*.ts"],
			"linter": {
				"rules": {
					"correctness": {
						"useHookAtTopLevel": "off"
					}
				}
			}
		}
	]
}
