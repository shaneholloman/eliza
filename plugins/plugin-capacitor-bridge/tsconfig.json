{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"jsx": "react-jsx",
		"esModuleInterop": true,
		"strict": true,
		"strictNullChecks": true,
		"skipLibCheck": true,
		"ignoreDeprecations": "6.0",
		"declaration": true,
		"declarationMap": true,
		"outDir": "./dist",
		"rootDir": "../../../",
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"types": ["node", "bun"],
		"allowImportingTsExtensions": true,
		"rewriteRelativeImportExtensions": true,
		"paths": {
			"@elizaos/agent": ["../../packages/agent/src/index.ts"],
			"@elizaos/agent/*": ["../../packages/agent/src/*"],
			"@elizaos/app-core": ["./src/type-shims/app-core-root.ts"],
			"@elizaos/app-core/agent-bridge": [
				"../../packages/app-core/src/agent-bridge.ts"
			],
			"@elizaos/app-core/account-pool": [
				"../../packages/app-core/src/account-pool.ts"
			],
			"@elizaos/app-core/api/auth": ["../../packages/app-core/src/api/auth.ts"],
			"@elizaos/app-core/api/cloud-pair-route": [
				"../../packages/app-core/src/api/cloud-pair-route.ts"
			],
			"@elizaos/app-core/api/compat-route-shared": [
				"../../packages/app-core/src/api/compat-route-shared.ts"
			],
			"@elizaos/app-core/api/response": [
				"../../packages/app-core/src/api/response.ts"
			],
			"@elizaos/app-core/registry": [
				"../../packages/app-core/src/registry/index.ts"
			],
			"@elizaos/app-core/services/vault-mirror": [
				"../../packages/app-core/src/services/vault-mirror.ts"
			],
			"@elizaos/auth": ["../../packages/auth/src/index.ts"],
			"@elizaos/auth/*": ["../../packages/auth/src/*"],
			"@elizaos/capacitor-bun-runtime": [
				"../../plugins/plugin-native-bun-runtime/src/index.ts"
			],
			"@elizaos/capacitor-camera": [
				"../../plugins/plugin-native-camera/src/index.ts"
			],
			"@elizaos/core": ["../../packages/core/src/index.node.ts"],
			"@elizaos/import-conversations": [
				"../../packages/import-conversations/src/index.ts"
			],
			"@elizaos/import-conversations/browser": [
				"../../packages/import-conversations/src/browser.ts"
			],
			"@elizaos/logger": ["../../packages/logger/src/index.ts"],
			"@elizaos/shared": ["../../packages/shared/src/index.ts"],
			"@elizaos/shared/*": ["../../packages/shared/src/*"],
			"@elizaos/ui": ["../../packages/ui/src/index.ts"],
			"@elizaos/ui/agent-surface": [
				"../../packages/ui/src/agent-surface/index.ts"
			],
			"@elizaos/ui/api/*": ["../../packages/ui/src/api/*"],
			"@elizaos/ui/components/*": ["../../packages/ui/src/components/*"],
			"@elizaos/ui/state": ["../../packages/ui/src/state/index.ts"],
			"@elizaos/ui/state/*": ["../../packages/ui/src/state/*"],
			"@elizaos/ui/agent-surface/types": [
				"../../packages/ui/src/agent-surface/types.ts"
			],
			"@elizaos/ui/views/view-interact-protocol": [
				"../../packages/ui/src/views/view-interact-protocol.ts"
			],
			"@elizaos/vault": ["../../packages/vault/src/index.ts"],
			"@elizaos/plugin-agent-skills": [
				"../../plugins/plugin-agent-skills/src/index.ts"
			],
			"@elizaos/plugin-agent-skills/*": [
				"../../plugins/plugin-agent-skills/src/*"
			],
			"@elizaos/plugin-app-control": [
				"../../plugins/plugin-app-control/src/index.ts"
			],
			"@elizaos/plugin-app-control/*": [
				"../../plugins/plugin-app-control/src/*"
			],
			"@elizaos/plugin-app-manager": [
				"../../plugins/plugin-app-manager/src/index.ts"
			],
			"@elizaos/plugin-app-manager/*": [
				"../../plugins/plugin-app-manager/src/*"
			],
			"@elizaos/plugin-aosp-local-inference": [
				"../../plugins/plugin-aosp-local-inference/src/index.ts"
			],
			"@elizaos/plugin-aosp-local-inference/*": [
				"../../plugins/plugin-aosp-local-inference/src/*"
			],
			"@elizaos/plugin-browser": ["../../plugins/plugin-browser/src/index.ts"],
			"@elizaos/plugin-browser/*": ["../../plugins/plugin-browser/src/*"],
			"@elizaos/plugin-capacitor-bridge": ["./src/index.ts"],
			"@elizaos/plugin-capacitor-bridge/*": ["./src/*"],
			"@elizaos/plugin-coding-tools": [
				"../../plugins/plugin-coding-tools/src/index.ts"
			],
			"@elizaos/plugin-coding-tools/*": [
				"../../plugins/plugin-coding-tools/src/*"
			],
			"@elizaos/plugin-commands": [
				"../../plugins/plugin-commands/src/index.ts"
			],
			"@elizaos/plugin-discord/service": [
				"../../plugins/plugin-discord/service.ts"
			],
			"@elizaos/plugin-meetings": [
				"../../plugins/plugin-meetings/src/index.ts"
			],
			"@elizaos/plugin-meetings/*": ["../../plugins/plugin-meetings/src/*"],
			"@elizaos/plugin-elizacloud/host-routes": [
				"../../plugins/plugin-elizacloud/src/host-routes.ts"
			],
			"@elizaos/plugin-local-inference": [
				"../../plugins/plugin-local-inference/src/index.ts"
			],
			"@elizaos/plugin-local-inference/*": [
				"../../plugins/plugin-local-inference/src/*"
			],
			"@elizaos/plugin-remote-manifest": [
				"../../packages/plugin-remote-manifest/src/index.ts"
			],
			"@elizaos/plugin-remote-manifest/*": [
				"../../packages/plugin-remote-manifest/src/*"
			],
			"@elizaos/plugin-registry": [
				"../../plugins/plugin-registry/src/index.ts"
			],
			"@elizaos/plugin-registry/*": ["../../plugins/plugin-registry/src/*"],
			"@elizaos/plugin-streaming": [
				"../../plugins/plugin-streaming/src/index.ts"
			],
			"@elizaos/plugin-scheduling": [
				"../../plugins/plugin-scheduling/src/index.ts"
			],
			"@elizaos/plugin-scheduling/*": ["../../plugins/plugin-scheduling/src/*"],
			"@elizaos/plugin-sql": ["../../plugins/plugin-sql/src/index.node.ts"],
			"@elizaos/plugin-task-coordinator": [
				"../../plugins/plugin-task-coordinator/src/index.ts"
			],
			"@elizaos/plugin-task-coordinator/*": [
				"../../plugins/plugin-task-coordinator/src/*"
			],
			"@elizaos/plugin-worker-runtime": [
				"../../packages/plugin-worker-runtime/src/index.ts"
			],
			"@elizaos/plugin-worker-runtime/*": [
				"../../packages/plugin-worker-runtime/src/*"
			],
			"@elizaos/plugin-wallet": ["../../plugins/plugin-wallet/src/index.ts"],
			"@elizaos/plugin-wallet/*": ["../../plugins/plugin-wallet/src/*"],
			"@elizaos/plugin-x402": ["../../plugins/plugin-x402/src/index.ts"],
			"@elizaos/plugin-x402/*": ["../../plugins/plugin-x402/src/*"]
		}
	},
	"include": ["src/**/*"],
	"exclude": [
		"node_modules",
		"dist",
		"src/**/__tests__/**",
		"src/**/*.test.ts",
		"src/**/*.test.tsx",
		"**/__tests__/**",
		"**/*.test.ts",
		"**/*.test.tsx",
		"**/*.e2e.test.ts"
	]
}
