{
  "name": "@elizaos/plugin-ainex",
  "description": "Drives Hiwonder AiNex (and other) humanoid robots via a websocket bridge; integrates camera into plugin-vision and exposes joystick + servo + action-group control to the agent.",
  "version": "2.0.3-beta.7",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "packageType": "plugin",
  "platform": "node",
  "license": "MIT",
  "author": "ElizaOS",
  "keywords": [
    "plugin",
    "elizaos",
    "robot",
    "robotics",
    "ainex",
    "hiwonder",
    "mujoco"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/elizaos/elizaos"
  },
  "homepage": "https://elizaos.ai",
  "bugs": {
    "url": "https://github.com/elizaos/elizaos/issues"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "eliza-source": {
        "types": "./src/index.ts",
        "import": "./src/index.ts",
        "default": "./src/index.ts"
      },
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "package.json",
    "build.config.ts"
  ],
  "elizaos": {
    "plugin": {
      "capabilities": [
        "robot",
        "ainex"
      ]
    }
  },
  "dependencies": {
    "@elizaos/core": "workspace:*",
    "sharp": "^0.34.3",
    "ws": "^8.18.0"
  },
  "peerDependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "^1.3.5",
    "@types/node": "^25.0.3",
    "@types/ws": "^8.5.12",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "scripts": {
    "build": "bun run build.ts",
    "clean": "node ../../packages/scripts/rm-path-recursive.mjs dist .turbo",
    "lint": "bunx @biomejs/biome check --write --unsafe .",
    "lint:check": "bunx @biomejs/biome check .",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run",
    "format": "bunx @biomejs/biome format --write .",
    "format:check": "bunx @biomejs/biome format ."
  },
  "publishConfig": {
    "access": "public"
  },
  "agentConfig": {
    "pluginType": "elizaos:plugin:1.0.0",
    "pluginParameters": {
      "ELIZA_AINEX_BRIDGE_URL": {
        "type": "string",
        "description": "Websocket URL for the AiNex bridge server (default: ws://localhost:9100)"
      },
      "ELIZA_AINEX_PROFILE": {
        "type": "string",
        "description": "Robot profile descriptor name (default: hiwonder-ainex)"
      },
      "ELIZA_AINEX_CAMERA_FPS": {
        "type": "number",
        "description": "Robot camera frame rate to subscribe to (default: 10)"
      }
    }
  },
  "eliza": {
    "platforms": [
      "node"
    ],
    "runtime": "node",
    "platformDetails": {
      "node": "Node.js only (platform: node)"
    }
  }
}
