{
	"$schema": "https://biomejs.dev/schemas/2.5.1/schema.json",
	"root": false,
	"files": {
		"includes": [
			"auto-enable.ts",
			"build.ts",
			"index.ts",
			"index.browser.ts",
			"index.node.ts",
			"vitest.config.ts",
			"src/**/*.ts",
			"__tests__/**/*.ts",
			"!**/*.js",
			"!**/*.d.ts",
			"!dist",
			"!node_modules"
		]
	},
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"preset": "recommended",
			"correctness": {
				"noUnusedVariables": "error"
			},
			"a11y": {
				"useButtonType": "off"
			},
			"style": {},
			"complexity": {
				"noCommaOperator": "off",
				"useLiteralKeys": "off"
			}
		}
	},
	"formatter": {
		"enabled": true,
		"indentWidth": 2,
		"indentStyle": "space",
		"lineWidth": 100
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"trailingCommas": "es5",
			"semicolons": "always"
		}
	}
}
