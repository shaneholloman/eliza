{
  "id": "edge-tts",
  "name": "Edge Tts",
  "description": "Free text-to-speech using Microsoft Edge TTS - no API key required",
  "npmName": "@elizaos/plugin-edge-tts",
  "version": "2.0.0-beta.0",
  "source": "bundled",
  "tags": ["edge-tts", "edge", "text-to-speech"],
  "config": {
    "EDGE_TTS_VOICE": {
      "type": "string",
      "required": false,
      "sensitive": false,
      "default": "en-US-MichelleNeural",
      "label": "Tts Voice",
      "help": "Voice ID to use for synthesis (e.g., en-US-MichelleNeural, en-GB-SoniaNeural)",
      "advanced": false
    },
    "EDGE_TTS_LANG": {
      "type": "string",
      "required": false,
      "sensitive": false,
      "default": "en-US",
      "label": "Tts Lang",
      "help": "Language code for synthesis (e.g., en-US, en-GB, de-DE)",
      "advanced": false
    },
    "EDGE_TTS_OUTPUT_FORMAT": {
      "type": "string",
      "required": false,
      "sensitive": false,
      "default": "audio-24khz-48kbitrate-mono-mp3",
      "label": "Tts Output Format",
      "help": "Output format for audio (e.g., audio-24khz-48kbitrate-mono-mp3, audio-48khz-96kbitrate-mono-mp3)",
      "advanced": false
    },
    "EDGE_TTS_RATE": {
      "type": "number",
      "required": false,
      "sensitive": false,
      "label": "Tts Rate",
      "help": "Speech rate adjustment (e.g., +0%, -10%, +20%)",
      "advanced": false
    },
    "EDGE_TTS_PITCH": {
      "type": "string",
      "required": false,
      "sensitive": false,
      "label": "Tts Pitch",
      "help": "Voice pitch adjustment (e.g., +0Hz, -10Hz, +5Hz)",
      "advanced": false
    },
    "EDGE_TTS_VOLUME": {
      "type": "string",
      "required": false,
      "sensitive": false,
      "label": "Tts Volume",
      "help": "Volume adjustment (e.g., +0%, -10%, +20%)",
      "advanced": false
    },
    "EDGE_TTS_PROXY": {
      "type": "string",
      "required": false,
      "sensitive": false,
      "label": "Tts Proxy",
      "help": "HTTP proxy URL for requests",
      "advanced": false
    },
    "EDGE_TTS_TIMEOUT_MS": {
      "type": "number",
      "required": false,
      "sensitive": false,
      "default": "30000",
      "label": "Tts Timeout Ms",
      "help": "Request timeout in milliseconds",
      "advanced": false,
      "min": 0,
      "unit": "ms"
    }
  },
  "render": {
    "visible": true,
    "pinTo": [],
    "style": "card",
    "icon": "Volume2",
    "group": "voice",
    "groupOrder": 3,
    "actions": ["enable", "configure"]
  },
  "resources": {
    "homepage": "https://github.com/elizaos/eliza#readme",
    "repository": "https://github.com/elizaos/eliza"
  },
  "dependsOn": [],
  "kind": "plugin",
  "subtype": "voice",
  "defaultTextToSpeech": true
}
