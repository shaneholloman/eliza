{
	"name": "@elizaos/plugin-local-inference",
	"version": "2.0.3-beta.7",
	"description": "Eliza-1 local provider plus HTTP routes for local model catalog, downloads, hardware detection, and chat commands.",
	"type": "module",
	"main": "dist/index.js",
	"types": "src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"eliza-source": {
				"types": "./src/index.ts",
				"import": "./src/index.ts",
				"default": "./src/index.ts"
			},
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./voice-wake": {
			"types": "./src/voice-wake.ts",
			"eliza-source": {
				"types": "./src/voice-wake.ts",
				"import": "./src/voice-wake.ts",
				"default": "./src/voice-wake.ts"
			},
			"import": "./dist/voice-wake.js",
			"default": "./dist/voice-wake.js"
		},
		"./runtime": {
			"types": "./src/runtime/index.ts",
			"eliza-source": {
				"types": "./src/runtime/index.ts",
				"import": "./src/runtime/index.ts",
				"default": "./src/runtime/index.ts"
			},
			"import": "./dist/runtime/index.js",
			"default": "./dist/runtime/index.js"
		},
		"./runtime/embedding-presets": {
			"types": "./src/runtime/embedding-presets.ts",
			"eliza-source": {
				"types": "./src/runtime/embedding-presets.ts",
				"import": "./src/runtime/embedding-presets.ts",
				"default": "./src/runtime/embedding-presets.ts"
			},
			"import": "./dist/runtime/index.js",
			"default": "./dist/runtime/index.js"
		},
		"./routes": {
			"types": "./src/routes/index.ts",
			"eliza-source": {
				"types": "./src/routes/index.ts",
				"import": "./src/routes/index.ts",
				"default": "./src/routes/index.ts"
			},
			"import": "./dist/routes/index.js",
			"default": "./dist/routes/index.js"
		},
		"./local-inference-routes": {
			"types": "./src/local-inference-routes.ts",
			"eliza-source": {
				"types": "./src/local-inference-routes.ts",
				"import": "./src/local-inference-routes.ts",
				"default": "./src/local-inference-routes.ts"
			},
			"import": "./dist/local-inference-routes.js",
			"default": "./dist/local-inference-routes.js"
		},
		"./services": {
			"types": "./src/services/index.ts",
			"eliza-source": {
				"types": "./src/services/index.ts",
				"import": "./src/services/index.ts",
				"default": "./src/services/index.ts"
			},
			"import": "./dist/services/index.js",
			"default": "./dist/services/index.js"
		},
		"./voice-workbench": {
			"types": "./src/voice-workbench.ts",
			"eliza-source": {
				"types": "./src/voice-workbench.ts",
				"import": "./src/voice-workbench.ts",
				"default": "./src/voice-workbench.ts"
			},
			"import": "./dist/voice-workbench.js",
			"default": "./dist/voice-workbench.js"
		},
		"./*.css": "./dist/*.css",
		"./*": {
			"types": "./src/*.ts",
			"eliza-source": {
				"types": "./src/*.ts",
				"import": "./src/*.ts",
				"default": "./src/*.ts"
			},
			"import": "./dist/*.js",
			"default": "./dist/*.js"
		}
	},
	"files": [
		"registry-entry.json",
		"dist",
		"src"
	],
	"scripts": {
		"build": "bun run build.ts",
		"dev": "bun run build.ts",
		"test": "NODE_OPTIONS='--experimental-sqlite' vitest run",
		"test:asr:real": "NODE_OPTIONS='--experimental-sqlite' bun scripts/asr-real-smoke.ts",
		"test:kokoro:real": "bun scripts/kokoro-real-smoke.ts",
		"probe:sd-cpp": "node scripts/probe-sd-cpp.mjs --human",
		"memory:benchmark": "bun run scripts/memory-benchmark.ts",
		"voice:workbench": "bun run scripts/voice-workbench.ts",
		"voice:bargein-bench": "node native/verify/bargein_latency_harness.mjs",
		"voice:endurance": "node native/verify/thirty_turn_endurance_harness.mjs",
		"voice:mobile-rss": "node native/verify/mobile_peak_rss_harness.mjs",
		"eliza1:gates": "node native/verify/eliza1_gates_collect.mjs",
		"lifecycle:matrix": "bun scripts/local-model-lifecycle-matrix.ts",
		"corpus:generate": "bun run scripts/generate-voice-corpus.ts",
		"sttquant:real": "NODE_OPTIONS='--experimental-sqlite' bun scripts/stt-quant-bench-real.ts",
		"noise:real": "NODE_OPTIONS='--experimental-sqlite' bun scripts/noise-rejection-real.ts",
		"speakeriso:real": "NODE_OPTIONS='--experimental-sqlite' bun scripts/speaker-isolation-real.ts",
		"roundtrip:real": "NODE_OPTIONS='--experimental-sqlite' bun scripts/mixed-real-roundtrip.ts",
		"robustness:real": "NODE_OPTIONS='--experimental-sqlite' bun scripts/real-robustness-asr.ts",
		"voicestack:real": "NODE_OPTIONS='--experimental-sqlite' bun scripts/real-voice-stack.ts",
		"agentvoice:real": "NODE_OPTIONS='--experimental-sqlite' bun scripts/real-agent-voice-overlap.ts",
		"clean": "node ../../packages/scripts/rm-path-recursive.mjs dist .turbo node_modules",
		"lint": "bunx @biomejs/biome check --write --unsafe .",
		"lint:check": "bunx @biomejs/biome check .",
		"format": "bunx @biomejs/biome format --write .",
		"format:check": "bunx @biomejs/biome format .",
		"typecheck": "tsgo --noEmit -p tsconfig.json"
	},
	"dependencies": {
		"@elizaos/agent": "workspace:*",
		"@elizaos/core": "workspace:*",
		"@elizaos/plugin-capacitor-bridge": "workspace:*",
		"@elizaos/plugin-computeruse": "workspace:*",
		"@elizaos/plugin-aosp-local-inference": "workspace:*",
		"@elizaos/shared": "workspace:*",
		"phonemizer": "^1.2.1",
		"ws": "^8.20.1"
	},
	"peerDependencies": {
		"@elizaos/core": "workspace:*",
		"@elizaos/shared": "workspace:*"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.2",
		"@types/node": "24.12.2",
		"@types/ws": "^8.18.1",
		"typescript": "^6.0.3",
		"vitest": "^4.1.4"
	},
	"publishConfig": {
		"access": "public"
	},
	"elizaos": {
		"scripts": {
			"coreBuild": true
		}
	}
}
