  "npmName": "@elizaos/plugin-browser",
  "shortIds": [
    "browser",
    "app-browser",
    "appBrowser",
    "eliza-browser",
    "elizaBrowser",
    "browser-bridge",
    "browserBridge"
  ],
  "version": "2.0.0-beta.0",
