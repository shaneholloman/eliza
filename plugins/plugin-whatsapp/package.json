{
  "name": "@elizaos/plugin-whatsapp",
  "description": "WhatsApp plugin for ElizaOS (Cloud API + Baileys QR auth)",
  "version": "2.0.3-beta.7",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "packageType": "plugin",
  "platform": "node",
  "license": "MIT",
  "keywords": [
    "plugin",
    "elizaos",
    "whatsapp"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/elizaos/eliza"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "eliza-source": {
        "types": "./src/index.ts",
        "import": "./src/index.ts",
        "default": "./src/index.ts"
      },
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./*.css": "./dist/*.css",
    "./*": {
      "types": "./dist/*.d.ts",
      "eliza-source": {
        "types": "./src/*.ts",
        "import": "./src/*.ts",
        "default": "./src/*.ts"
      },
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    }
  },
  "files": [
    "registry-entry.json",
    "dist",
    "README.md",
    "package.json",
    "auto-enable.ts"
  ],
  "elizaos": {
    "plugin": {
      "autoEnableModule": "./auto-enable.ts",
      "capabilities": [
        "messaging"
      ]
    }
  },
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "pino": "^10.3.1",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0"
  },
  "peerDependencies": {
    "@elizaos/core": "workspace:*"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@types/node": "^25.0.3",
    "@types/qrcode": "^1.5.5",
    "typescript": "^6.0.3",
    "vitest": "^4.0.0"
  },
  "scripts": {
    "dev": "bun --hot build.ts",
    "test": "vitest run --config ./vitest.config.ts",
    "lint": "bunx @biomejs/biome check --write --config-path ./biome.json .",
    "typecheck": "tsgo --noEmit -p tsconfig.json",
    "clean": "node ../../packages/scripts/rm-path-recursive.mjs dist .turbo",
    "lint:check": "bunx @biomejs/biome check --config-path ./biome.json .",
    "build": "bun run build.ts",
    "build:ts": "bun run build.ts",
    "format": "bunx @biomejs/biome format --write --config-path ./biome.json .",
    "format:check": "bunx @biomejs/biome format --config-path ./biome.json ."
  },
  "publishConfig": {
    "access": "public"
  },
  "agentConfig": {
    "pluginParameters": {
      "WHATSAPP_ACCESS_TOKEN": {
        "type": "string",
        "description": "Access token for WhatsApp Cloud API (required for cloudapi auth)",
        "required": false,
        "sensitive": true
      },
      "WHATSAPP_PHONE_NUMBER_ID": {
        "type": "string",
        "description": "Phone number ID for WhatsApp Cloud API (required for cloudapi auth)",
        "required": false,
        "sensitive": false
      },
      "WHATSAPP_AUTH_METHOD": {
        "type": "string",
        "description": "Authentication method: cloudapi or baileys",
        "required": false,
        "sensitive": false
      },
      "WHATSAPP_AUTH_DIR": {
        "type": "string",
        "description": "Directory used to persist Baileys session files (required for baileys auth)",
        "required": false,
        "sensitive": false
      },
      "WHATSAPP_PRINT_QR": {
        "type": "boolean",
        "description": "Print QR code in terminal when using Baileys auth",
        "required": false,
        "sensitive": false
      },
      "WHATSAPP_WEBHOOK_VERIFY_TOKEN": {
        "type": "string",
        "description": "Webhook verification token",
        "required": false,
        "sensitive": true
      },
      "WHATSAPP_APP_SECRET": {
        "type": "string",
        "description": "WhatsApp App Secret used to verify X-Hub-Signature-256 on webhook POSTs (required for Cloud API webhooks)",
        "required": false,
        "sensitive": true
      },
      "WHATSAPP_BUSINESS_ACCOUNT_ID": {
        "type": "string",
        "description": "Business account ID",
        "required": false,
        "sensitive": false
      },
      "WHATSAPP_API_VERSION": {
        "type": "string",
        "description": "API version string",
        "required": false,
        "sensitive": false
      },
      "WHATSAPP_DM_POLICY": {
        "type": "string",
        "description": "DM policy (e.g. allow, deny, allowlist)",
        "required": false,
        "sensitive": false
      },
      "WHATSAPP_GROUP_POLICY": {
        "type": "string",
        "description": "Group message policy",
        "required": false,
        "sensitive": false
      }
    }
  }
}
